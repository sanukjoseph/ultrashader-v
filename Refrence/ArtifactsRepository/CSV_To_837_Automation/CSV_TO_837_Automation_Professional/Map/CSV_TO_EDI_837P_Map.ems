if(Relationship_To_Sub == &quot;Self&quot;)
{
	
              if(Fields[0] != &quot;&quot; &amp;&amp; Fields[0] != undefined )
              { 
                             ec_ResultHelper.ReportResultByIndex(0,&quot;DQ&quot;);              
                             ec_ResultHelper.ReportResultByIndex(1,&quot;1&quot;);          
                             ec_ResultHelper.ReportResultByIndex(2,Fields[0]); 
                             ec_ResultHelper.ReportResultByIndex(3,Fields[1]);
							 
                             if(Fields[2] != &quot;&quot;)
                              { 
							 ec_ResultHelper.ReportResultByIndex(4,&quot;XX&quot;);
							 }
							 ec_ResultHelper.ReportResultByIndex(5,Fields[2]);
              }
              }
			  else{
