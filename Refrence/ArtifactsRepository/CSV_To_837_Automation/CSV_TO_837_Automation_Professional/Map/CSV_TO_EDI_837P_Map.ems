		<Function ID="217" Name="JavaScript_N3" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">12</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var data = ec_DataHelper.GetValueByIndex(0);
if (/,/.test(data)) 
{
var separatedData = data.split(&quot;,&quot;); // Split the string by comma
 
// Now you have an array with two elements
var firstData = separatedData[0];
var secondData = separatedData[1];
 
