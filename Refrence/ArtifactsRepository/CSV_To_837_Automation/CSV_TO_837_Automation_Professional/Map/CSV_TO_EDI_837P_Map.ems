			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var dataWithDots  = ec_DataHelper.GetValueByIndex(0);
var dataWithoutDots = dataWithDots.replace(/\./g, ''); // Replace all dots with an empty string
ec_ResultHelper.ReportResultByIndex(0,dataWithoutDots);

var dataWithDots    = ec_DataHelper.GetValueByIndex(1);
var dataWithoutDots = dataWithDots.replace(/\./g, ''); // Replace all dots with an empty string
ec_ResultHelper.ReportResultByIndex(1,dataWithoutDots);

