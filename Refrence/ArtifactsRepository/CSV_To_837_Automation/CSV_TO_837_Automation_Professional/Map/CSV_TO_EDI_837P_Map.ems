ec_ResultHelper.ReportResultByIndex(6,dataWithoutDots);

var dataWithDots    = ec_DataHelper.GetValueByIndex(7);
var dataWithoutDots = dataWithDots.replace(/\./g, ''); // Replace all dots with an empty string
ec_ResultHelper.ReportResultByIndex(7,dataWithoutDots);

var dataWithDots    = ec_DataHelper.GetValueByIndex(8);
