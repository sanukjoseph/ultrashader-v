		<Function ID="174" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">24</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var start_date = ec_DataHelper.GetValueByIndex(0);
var end_date = ec_DataHelper.GetValueByIndex(1);


var CLM_In_2000B    = ec_VariableHelper.GetVariable(&quot;CLM_In_2000B&quot;);


if(CLM_In_2000B == &quot;&quot; )
{
if( start_date != &quot;&quot; &amp;&amp; end_date != &quot;&quot;) 
{
	
   ec_ResultHelper.ReportResultByIndex(0,&quot;472&quot;);
   ec_ResultHelper.ReportResultByIndex(1,&quot;RD8&quot;);
   ec_ResultHelper.ReportResultByIndex(2,start_date  + &quot;-&quot; + end_date);
    
}
else
{  
	if( start_date != &quot;&quot;){
		
    ec_ResultHelper.ReportResultByIndex(0,&quot;472&quot;);
	ec_ResultHelper.ReportResultByIndex(1,&quot;D8&quot;);
    ec_ResultHelper.ReportResultByIndex(2,start_date);
}
}
}

</Property>
