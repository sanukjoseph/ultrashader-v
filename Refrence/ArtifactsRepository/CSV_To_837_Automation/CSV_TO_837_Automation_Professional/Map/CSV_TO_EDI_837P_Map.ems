		<Function ID="214" Name="ST_SE_Count" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">35</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var st02 = ec_DataHelper.GetValueByIndex(0);
st02 = 1+ +st02;
var string = st02.toString();
while(string.length&lt;4)
string = &quot;0&quot; + string;
ec_ResultHelper.ReportResultByIndex(0,string);</Property>
			</Properties>
