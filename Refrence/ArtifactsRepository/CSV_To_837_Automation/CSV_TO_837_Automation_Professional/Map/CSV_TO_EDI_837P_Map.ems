ec_ResultHelper.ReportResultByIndex(4,dataWithoutDots);

var dataWithDots    = ec_DataHelper.GetValueByIndex(5);
var dataWithoutDots = dataWithDots.replace(/\./g, ''); // Replace all dots with an empty string
ec_ResultHelper.ReportResultByIndex(5,dataWithoutDots);

var dataWithDots    = ec_DataHelper.GetValueByIndex(6);
