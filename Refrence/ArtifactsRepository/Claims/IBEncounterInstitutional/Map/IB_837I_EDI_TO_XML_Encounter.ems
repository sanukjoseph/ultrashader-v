		<Function ID="70" Name="JavaScript-Output_External Cause of Injury" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">8</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var myRS = ec_VariableHelper.GetRecordSet(&quot;ExternalCauseOfInjury_2000B&quot;);
var Fields = myRS.getFields(); // Retrieve the fields inside the recordSet

for (var i = 0; i &lt; Fields.length; i++) {
    if (i % 2 === 0) { // Even index: industry code
        var industryCode = Fields[i];
        if (industryCode.length &gt; 3) {
            industryCode = industryCode.slice(0, 3) + '.' +industryCode.slice(3);
        }
		 if(industryCode!=&quot;&quot;)
		 {	 
        ec_ResultHelper.ReportResultByIndex(i,industryCode);
		 }
    } else { // Odd index: responseCode
	 if( Fields[i]!=&quot;&quot;)
	 {
        ec_ResultHelper.ReportResultByIndex(i, Fields[i]);
     }
}
}
</Property>
