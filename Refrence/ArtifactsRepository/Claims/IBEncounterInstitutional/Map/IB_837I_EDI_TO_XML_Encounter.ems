		<Function ID="176" Name="JavaScript-SenderID/ReceiverID" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">1</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{cd0f31c1-8605-4eb4-818b-3e5fa264446e}">Mapping senderid and receiverid by triming the values using javascript
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">
var ISA06 = ec_DataHelper.GetValueByIndex(0); //sender ID
var ISA08 = ec_DataHelper.GetValueByIndex(1); //receiver ID
ec_ResultHelper.ReportResultByIndex(0,ISA06.trim());
ec_ResultHelper.ReportResultByIndex(1,ISA08.trim());

</Property>
