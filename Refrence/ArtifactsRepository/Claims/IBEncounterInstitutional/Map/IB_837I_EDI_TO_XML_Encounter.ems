var DTP02 = ec_VariableHelper.GetVariable(&quot;AdmissionDateQual_2000B&quot;);

var date=   ec_VariableHelper.GetVariable(&quot;AdmissionDate_2000B&quot;);
 if(DTP02==&quot;DT&quot;)
