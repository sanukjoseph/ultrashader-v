		<Function ID="57" Name="JavaScript-primaryDiagnosisCode" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">8</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var diagnosisCode = ec_VariableHelper.GetVariable(&quot;HI_PrincipalDiagnosisCode_2000B&quot;);

// Add a dot after the 3rd character if length is more than 3
if (diagnosisCode.length &gt; 3) {
    diagnosisCode = diagnosisCode.slice(0, 3) + '.' + diagnosisCode.slice(3);
}

ec_ResultHelper.ReportResultByIndex(0, diagnosisCode);
</Property>
