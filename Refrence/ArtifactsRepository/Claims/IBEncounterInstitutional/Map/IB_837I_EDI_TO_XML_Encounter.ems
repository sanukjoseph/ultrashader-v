		<Function ID="129" Name="JavaScript-Output_Occurance Information" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">12</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var myRS = ec_VariableHelper.GetRecordSet(&quot;ValueInfo_2000C&quot;);
var Fields = myRS.getFields(); // Retrieve the fields inside the recordSet

for (var i = 0; i &lt; Fields.length; i++) {
	
	if(Fields[i]!=0)
	{
    
        ec_ResultHelper.ReportResultByIndex(i, Fields[i]);
   
    }
 }	

</Property>
