		<Function ID="130" Name="JavaScript_Attending Provider(2000B)" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">13</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS1 = ec_VariableHelper.GetRecordSet(&quot;AttendingProvider_2000B&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
 resArr1 = new Array();
 
 for(i=0;i&lt;5;i++)
 {
 	resArr1[i] = ec_DataHelper.GetValueByIndex(i);
 }
//Updating the newly inserted row with the values from the array
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;AttendingProvider_2000B&quot;,myRS1, true);
</Property>
