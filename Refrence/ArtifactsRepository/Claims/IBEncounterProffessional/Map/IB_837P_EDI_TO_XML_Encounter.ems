		<Function ID="244" Name="JavaScript-SenderID/ReceiverID" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">1</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{4f3b125a-5230-4b90-95bf-80e2cd4805b8}">Mapping senderid and receiverid by triming the values using javascript
</Property>
