		<Function ID="38" Name="JavaScript_Output_ClaimInfo" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">6</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieve the record set
myRS = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_2300_Input_2000B&quot;);
var SV105=ec_VariableHelper.GetVariable(&quot;SV105_2400_facilityCode_2000B&quot;);

Fields = myRS.getFields();// Get the fields of the record set


for(var i = 0; i &lt; 2; i++)
{
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
	
}
 if(SV105 == &quot;&quot;)
 {
	 
	 ec_ResultHelper.ReportResultByIndex(2,Fields[2]);
 }
 ec_ResultHelper.ReportResultByIndex(3,Fields[3]);

if(Fields[4]==&quot;A&quot;)
 {
 	ec_ResultHelper.ReportResultByIndex(4,&quot;Y&quot;);
 }
else if(Fields[4]==&quot;C&quot;)
{
    ec_ResultHelper.ReportResultByIndex(4,&quot;N&quot;);
 	
}
for( var i=5; i&lt;7;i++)
{	
ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
}	 
</Property>
