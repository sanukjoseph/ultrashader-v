		<Function ID="37" Name="JavaScript_Input_ClaimInfo" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">6</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{4f3b125a-5230-4b90-95bf-80e2cd4805b8}">Record set for first 7 input values of 2300 loop
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_2300_Input_2000B&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
 resArr = new Array();
 
 for(i=0;i&lt;7;i++)
 {
 	resArr[i] = ec_DataHelper.GetValueByIndex(i);
 }
//Updating the newly inserted row with the values from the array
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_2300_Input_2000B&quot;, myRS, true);</Property>
			</Properties>
