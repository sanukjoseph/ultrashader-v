			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">
var ISA06 = ec_DataHelper.GetValueByIndex(0); //sender ID
var ISA08 = ec_DataHelper.GetValueByIndex(1); //receiver ID
ec_ResultHelper.ReportResultByIndex(0,ISA06.trim());
ec_ResultHelper.ReportResultByIndex(1,ISA08.trim());

