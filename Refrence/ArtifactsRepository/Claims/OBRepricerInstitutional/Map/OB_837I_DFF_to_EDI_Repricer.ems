			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;ServicLine_2400_2000B&quot;);
var Relationship_To_Sub    = ec_VariableHelper.GetVariable(&quot;Relationship_To_Sub&quot;);
 
Fields = myRS.getFields();
if(Relationship_To_Sub != &quot;18&quot; )
{
for(var i = 0; i &lt; 12; i++)// Report the value of the field at index i
{
    if(Fields[i] != &quot;&quot; &amp;&amp; Fields[i] != undefined )
    { 
		ec_ResultHelper.ReportResultByIndex(2*i,&quot;BG&quot;);
		ec_ResultHelper.ReportResultByIndex((2*i)+1,(Fields[i]).replace(/\./g,''));

	}
}
}</Property>
