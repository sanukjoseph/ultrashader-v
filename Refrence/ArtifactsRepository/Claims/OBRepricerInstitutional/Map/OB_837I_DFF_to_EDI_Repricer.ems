		<Function ID="571" Name="Other_Procedure_Information_Trigger_2000C" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">32</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Principal_Procedure_Information_2300&quot;);
var Relationship_To_Sub    = ec_VariableHelper.GetVariable(&quot;Relationship_To_Sub&quot;);
Fields = myRS.getFields();
if(Relationship_To_Sub != &quot;18&quot; )
{

for (var i = 0; i &lt; 12; i++) 
{
	if(Fields[(2 * i)] !=&quot;&quot; &amp;&amp; Fields[(2 * i)] != undefined)
		{
		    ec_ResultHelper.ReportResultByIndex((4 * i), &quot;BBQ&quot;);
		    ec_ResultHelper.ReportResultByIndex((4 * i) + 1, Fields[2 * i]);
    
		}
	   // ec_ResultHelper.ReportResultByIndex((4 * i) + 1, Fields[2 * i]);
    
		if(Fields[(2 * i )+ 1] !=&quot;&quot;)
		{
		   ec_ResultHelper.ReportResultByIndex(((4 * i) + 2), &quot;D8&quot;);
		}
	ec_ResultHelper.ReportResultByIndex(((4 * i) + 3), Fields[(2 * i )+ 1]);
}
}
</Property>
