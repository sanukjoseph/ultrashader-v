		<Function ID="572" Name="Occurence_Span_Information_2000C" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">34</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Occurrence_Span_Information&quot;);
var Relationship_To_Sub    = ec_VariableHelper.GetVariable(&quot;Relationship_To_Sub&quot;);
Fields = myRS.getFields();
if(Relationship_To_Sub != &quot;18&quot; )
{

for (var i = 0; i &lt; 12; i++) {
	
			if(Fields[(3 * i)] !=&quot;&quot; &amp;&amp; Fields[(3 * i)] != undefined )
			{
		        ec_ResultHelper.ReportResultByIndex((4 * i), &quot;BI&quot;);
		         ec_ResultHelper.ReportResultByIndex((4 * i) + 1, (Fields[3 * i]).replace(/\./g,''));

    		    }
      //ec_ResultHelper.ReportResultByIndex((4 * i) + 1, Fields[3 * i]);
    
			if(Fields[(3 * i )+ 1] + Fields[(3 * i )+ 2] !=&quot;&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(((4 * i) + 2), &quot;RD8&quot;);
			ec_ResultHelper.ReportResultByIndex(((4 * i) + 3), Fields[(3 * i )+ 1] +&quot;-&quot;+ Fields[(3 * i )+ 2]);
		    }
}
}
</Property>
