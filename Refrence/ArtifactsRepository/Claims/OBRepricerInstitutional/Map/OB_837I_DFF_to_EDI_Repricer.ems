		<Function ID="568" Name="Principal_Procedure_Information_2000C" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">31</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var PRINCIPAL_PROCEDURE    = ec_VariableHelper.GetVariable(&quot;PRINCIPAL_PROCEDURE&quot;);
var PRINCIPAL_PROCEDURE_DATE    = ec_VariableHelper.GetVariable(&quot;PRINCIPAL_PROCEDURE_DATE&quot;);
var Relationship_To_Sub    = ec_VariableHelper.GetVariable(&quot;Relationship_To_Sub&quot;);

if(Relationship_To_Sub != &quot;18&quot; )
{
for (var i = 0; i &lt; 1; i++) {
	
		if(PRINCIPAL_PROCEDURE !=&quot;&quot;)
		{
	        ec_ResultHelper.ReportResultByIndex((4 * i), &quot;BBR&quot;);
	    }
    ec_ResultHelper.ReportResultByIndex((4 * i) + 1, (PRINCIPAL_PROCEDURE).replace(/\./g,''));

    
		if(PRINCIPAL_PROCEDURE_DATE !=&quot;&quot;)
		{
		    ec_ResultHelper.ReportResultByIndex(((4 * i) + 2), &quot;D8&quot;);
		}
	ec_ResultHelper.ReportResultByIndex(((4 * i) + 3), (PRINCIPAL_PROCEDURE_DATE).replace(/\./g,''));

}
}
</Property>
