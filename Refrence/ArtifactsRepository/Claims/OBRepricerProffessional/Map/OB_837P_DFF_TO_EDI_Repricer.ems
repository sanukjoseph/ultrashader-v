		<Function ID="155" Name="JavaScript_Diagnosis_Code_2000C" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">7</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;ServicLine_2400_2000B&quot;);
var Relationship_To_Sub=ec_VariableHelper.GetVariable(&quot;RELATIONSHIP_TO_SUB&quot;);
//ec_ResultHelper.println(&quot;status&quot;+Relationship_To_Sub);
Fields = myRS.getFields();
if(Relationship_To_Sub != '18' )
{
 
for(var i = 0; i &lt; 13; i++)// Report the value of the field at index i
	{
	    if(Fields[i] != &quot;&quot; )
	    { 
			ec_ResultHelper.ReportResultByIndex(2*i,&quot;ABF&quot;);
			ec_ResultHelper.ReportResultByIndex((2*i)+1,Fields[i].replace(/\./g,''));

		}
	}
}</Property>
