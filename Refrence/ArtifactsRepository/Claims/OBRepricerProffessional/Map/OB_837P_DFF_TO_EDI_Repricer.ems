ec_ResultHelper.ReportResultByIndex(4,&quot;1&quot;);
ec_ResultHelper.ReportResultByIndex(5,&quot;MI&quot;);
ec_ResultHelper.ReportResultByIndex(6,&quot;2&quot;);
