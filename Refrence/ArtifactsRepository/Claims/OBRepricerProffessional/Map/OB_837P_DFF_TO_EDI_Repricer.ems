			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var SBR02 = ec_VariableHelper.GetVariable(&quot;RELATIONSHIP_TO_SUB&quot;)

ec_ResultHelper.ReportResultByIndex(0,&quot;22&quot;);
ec_ResultHelper.ReportResultByIndex(1,&quot;P&quot;);

if (SBR02 == &quot;18&quot;)
{
	ec_ResultHelper.ReportResultByIndex(2,&quot;18&quot;);
}

