		<Function ID="185" Name="JavaScript_2400_2000C" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">9</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var Relationship_To_Sub    = ec_VariableHelper.GetVariable(&quot;RELATIONSHIP_TO_SUB&quot;);
var resArr1 = new Array(10); // Initialize resArr1 with a specific size
for (var i = 0; i &lt; 10; i++) 
{
    resArr1[i] = ec_DataHelper.GetValueByIndex(i);
}
if(Relationship_To_Sub != &quot;18&quot; )
{
 for (var i = 0; i &lt; 10; i++) 
	{
		ec_ResultHelper.ReportResultByIndex(i, resArr1[i]);
	}
}</Property>
			</Properties>
