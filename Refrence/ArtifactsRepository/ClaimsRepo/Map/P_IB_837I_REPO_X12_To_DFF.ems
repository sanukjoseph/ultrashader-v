resArr1[17] = ec_DataHelper.GetValueByIndex(17);
resArr1[18] = ec_DataHelper.GetValueByIndex(18);


//Updating the newly inserted row with the values from the array
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;Details_2320B_CAS&quot;, myRS1, true);</Property>
