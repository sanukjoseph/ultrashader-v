			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var myRS1 = ec_VariableHelper.GetRecordSet(&quot;Details_2320B_CAS&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
var resArr1 = new Array();

resArr1[0] = ec_DataHelper.GetValueByIndex(0);
resArr1[1] = ec_DataHelper.GetValueByIndex(1);
resArr1[2] = ec_DataHelper.GetValueByIndex(2);
resArr1[3] = ec_DataHelper.GetValueByIndex(3);
