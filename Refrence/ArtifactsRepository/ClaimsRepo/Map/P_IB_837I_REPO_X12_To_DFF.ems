		<Function ID="138" Name="JavaScript_2000B_2410_Input" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">10</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var myRS1 = ec_VariableHelper.GetRecordSet(&quot;Details_2410_2000B&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
var resArr1 = new Array();

resArr1[0] = ec_DataHelper.GetValueByIndex(0);
resArr1[1] = ec_DataHelper.GetValueByIndex(1);
resArr1[2] = ec_DataHelper.GetValueByIndex(2);
resArr1[3] = ec_DataHelper.GetValueByIndex(3);


//Updating the newly inserted row with the values from the array
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;Details_2410_2000B&quot;, myRS1, true);</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab10/XPos">64</Property>
				<Property Name="Tab10/YPos">-496</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="1030" FP="A" Pos="0" Name="value1">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="1031" FP="A" Pos="1" Name="value2">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="1032" FP="A" Pos="2" Name="value3">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="1033" FP="A" Pos="3" Name="value4">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="1029" FP="X" Pos="0" Name="result1"/>
			</ConnectionPoints>
		</Function>
		<Function ID="139" Name="JavaScript_2000B_2410_Output" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">10</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var isDependentPresent = ec_VariableHelper.GetVariable(&quot;isDependentPresent&quot;);
var myRS = ec_VariableHelper.GetRecordSet(&quot;Details_2410_2000B&quot;);
myRS.last();
var RS = myRS.getRow();
if (isDependentPresent == &quot;false&quot;)
{
	while(RS&gt;0)
	{
		var Fields = myRS.getFields();		
		{
	   	  	ec_ResultHelper.ReportResultByIndex(0,Fields[0]);
	   	  	ec_ResultHelper.ReportResultByIndex(1,Fields[1]);	
            ec_ResultHelper.ReportResultByIndex(2,Fields[2]);
            ec_ResultHelper.ReportResultByIndex(3,Fields[3]);
        }
		
		myRS.previous();
		RS = myRS.getRow();
	}
}	</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab10/XPos">64</Property>
				<Property Name="Tab10/YPos">-368</Property>
			</Properties>
			<ConnectionPoints>
