					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="1043" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="1038" FP="X" Pos="0" Name="result1"/>
				<ConnectionPoint ID="1039" FP="X" Pos="1" Name="result2"/>
				<ConnectionPoint ID="1040" FP="X" Pos="2" Name="result3"/>
				<ConnectionPoint ID="1041" FP="X" Pos="3" Name="result4"/>
			</ConnectionPoints>
		</Function>
