resArr1[0] = ec_DataHelper.GetValueByIndex(0);
resArr1[1] = ec_DataHelper.GetValueByIndex(1);
resArr1[2] = ec_DataHelper.GetValueByIndex(2);
resArr1[3] = ec_DataHelper.GetValueByIndex(3);
resArr1[4] = ec_DataHelper.GetValueByIndex(4);
resArr1[5] = ec_DataHelper.GetValueByIndex(5);
resArr1[6] = ec_DataHelper.GetValueByIndex(6);


//Updating the newly inserted row with the values from the array
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;Details_2000A&quot;, myRS1, true);</Property>
