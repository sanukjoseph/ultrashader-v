		<Function ID="347" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">27</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var isDependentPresent = ec_VariableHelper.GetVariable(&quot;isDependentPresent&quot;);
var myRS = ec_VariableHelper.GetRecordSet(&quot;Details_2420_C&quot;);
myRS.last();
var RS = myRS.getRow();
if (isDependentPresent == &quot;true&quot;)
{

	while(RS&gt;0)
	{
		var Fields = myRS.getFields();		
		{
	   	  	ec_ResultHelper.ReportResultByIndex(0,Fields[0]);
	   	  	ec_ResultHelper.ReportResultByIndex(1,Fields[1]);	
            ec_ResultHelper.ReportResultByIndex(2,Fields[2]);
            ec_ResultHelper.ReportResultByIndex(3,Fields[3]);
            ec_ResultHelper.ReportResultByIndex(4,Fields[4]);
            ec_ResultHelper.ReportResultByIndex(5,Fields[5]);
            ec_ResultHelper.ReportResultByIndex(6,Fields[6]);	
            ec_ResultHelper.ReportResultByIndex(7,Fields[7]);	
            ec_ResultHelper.ReportResultByIndex(8,Fields[8]);
            ec_ResultHelper.ReportResultByIndex(9,Fields[9]);
            ec_ResultHelper.ReportResultByIndex(10,Fields[10]);	
            ec_ResultHelper.ReportResultByIndex(11,Fields[11]);	
            ec_ResultHelper.ReportResultByIndex(12,Fields[12]);	
            ec_ResultHelper.ReportResultByIndex(13,Fields[13]);	
            ec_ResultHelper.ReportResultByIndex(14,Fields[14]);	
            ec_ResultHelper.ReportResultByIndex(15,Fields[15]);	
            ec_ResultHelper.ReportResultByIndex(16,Fields[16]);	
            ec_ResultHelper.ReportResultByIndex(17,Fields[17]);	
            ec_ResultHelper.ReportResultByIndex(18,Fields[18]);	
            ec_ResultHelper.ReportResultByIndex(19,Fields[19]);	
            ec_ResultHelper.ReportResultByIndex(20,Fields[20]);	
            ec_ResultHelper.ReportResultByIndex(21,Fields[21]);	
            ec_ResultHelper.ReportResultByIndex(22,Fields[22]);	
        }
		
		myRS.previous();
		RS = myRS.getRow();
	}
}</Property>
			</Properties>
