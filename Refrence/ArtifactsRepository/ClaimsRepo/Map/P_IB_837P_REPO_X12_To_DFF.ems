			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var isDependentPresent = ec_VariableHelper.GetVariable(&quot;isDependentPresent&quot;);
var myRS = ec_VariableHelper.GetRecordSet(&quot;Details_2010AA&quot;);
myRS.last();
var RS = myRS.getRow();

	while(RS&gt;0)
	{
		var Fields = myRS.getFields();
		
			for (var i = 0; i &lt; 6; i++) 
			{
				ec_ResultHelper.ReportResultByIndex(i, Fields[i]);	
			}
	   	  		       
		
		myRS.previous();
		RS = myRS.getRow();
	}</Property>
