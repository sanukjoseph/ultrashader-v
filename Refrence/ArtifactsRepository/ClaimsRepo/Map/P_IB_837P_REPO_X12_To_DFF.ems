		<Function ID="466" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">29</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var myRS1 = ec_VariableHelper.GetRecordSet(&quot;Details_BHT&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
var resArr1 = new Array();

resArr1[0] = ec_DataHelper.GetValueByIndex(0);
resArr1[1] = ec_DataHelper.GetValueByIndex(1);

//Updating the newly inserted row with the values from the array
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;Details_BHT&quot;, myRS1, true);</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab29/XPos">80</Property>
				<Property Name="Tab29/YPos">-64</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="4144" FP="A" Pos="0" Name="value1">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="4235" FP="A" Pos="1" Name="value2">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="4145" FP="X" Pos="0" Name="result1"/>
			</ConnectionPoints>
		</Function>
		<Function ID="468" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">29</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var isDependentPresent = ec_VariableHelper.GetVariable(&quot;isDependentPresent&quot;);
var myRS = ec_VariableHelper.GetRecordSet(&quot;Details_BHT&quot;);
myRS.last();
var RS = myRS.getRow();

	while(RS&gt;0)
	{
		var Fields = myRS.getFields();
		if(isDependentPresent == &quot;false&quot;)		
		{
	   	  	ec_ResultHelper.ReportResultByIndex(0,Fields[0]);
	   	  	ec_ResultHelper.ReportResultByIndex(1,Fields[1]);		       
		}
		else	
		{
	   	  	ec_ResultHelper.ReportResultByIndex(2,Fields[0]);
	   	  	ec_ResultHelper.ReportResultByIndex(3,Fields[1]);		       
		}
			
		myRS.previous();
		RS = myRS.getRow();
	}</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab29/XPos">224</Property>
				<Property Name="Tab29/YPos">16</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="4159" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="4160" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="4155" FP="X" Pos="0" Name="result1"/>
				<ConnectionPoint ID="4156" FP="X" Pos="1" Name="result2"/>
				<ConnectionPoint ID="4244" FP="X" Pos="2" Name="result3"/>
				<ConnectionPoint ID="4245" FP="X" Pos="3" Name="result4"/>
			</ConnectionPoints>
		</Function>
