		<Function ID="370" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">21</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var isDependentPresent = ec_VariableHelper.GetVariable(&quot;isDependentPresent&quot;);
var myRS = ec_VariableHelper.GetRecordSet(&quot;Details_2410_C&quot;);
myRS.last();
var RS = myRS.getRow();
if (isDependentPresent == &quot;true&quot;)
{
	while(RS&gt;0)
	{
		var Fields = myRS.getFields();		
		{
	   	  	ec_ResultHelper.ReportResultByIndex(0,Fields[0]);
	   	  	ec_ResultHelper.ReportResultByIndex(1,Fields[1]);	
            ec_ResultHelper.ReportResultByIndex(2,Fields[2]);
            ec_ResultHelper.ReportResultByIndex(3,Fields[3]);
        }
		
		myRS.previous();
		RS = myRS.getRow();
	}
}	</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab21/XPos">304</Property>
				<Property Name="Tab21/YPos">-880</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="3779" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="3780" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="3775" FP="X" Pos="0" Name="result1"/>
				<ConnectionPoint ID="3776" FP="X" Pos="1" Name="result2"/>
				<ConnectionPoint ID="3777" FP="X" Pos="2" Name="result3"/>
				<ConnectionPoint ID="3778" FP="X" Pos="3" Name="result4"/>
			</ConnectionPoints>
		</Function>
		<Function ID="374" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">25</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var CAS01 = ec_DataHelper.GetValueByIndex(0);
var CAS03 = ec_DataHelper.GetValueByIndex(1);
var CAS06 = ec_DataHelper.GetValueByIndex(2);
var CAS09 = ec_DataHelper.GetValueByIndex(3);
var CAS12 = ec_DataHelper.GetValueByIndex(4);
var CAS15 = ec_DataHelper.GetValueByIndex(5);
var CAS18 = ec_DataHelper.GetValueByIndex(6);
//TotalPRAmnt=0;

if(CAS01 == &quot;PR&quot; &amp;&amp; CAS01 != &quot;undefined&quot;)
{
	var PRAmnt = (parseFloat(CAS03) || 0) + (parseFloat(CAS06) || 0) + (parseFloat(CAS09) || 0) + (parseFloat(CAS12) || 0) + (parseFloat(CAS15) || 0) + (parseFloat(CAS18) || 0);
	//TotalPRAmnt = parseInt(TotalPRAmnt)+parseInt(PRAmnt);
	ec_ResultHelper.ReportResultByIndex(0,PRAmnt);
}
 
//ec_ResultHelper.println(&quot;PRAmnt=&quot;+PRAmnt);
</Property>
