			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var NM101_2420F = ec_DataHelper.GetValueByIndex(0);
var lastName = ec_DataHelper.GetValueByIndex(1);
var firstName = ec_DataHelper.GetValueByIndex(2);
var middleName = ec_DataHelper.GetValueByIndex(3);
var suffix = ec_DataHelper.GetValueByIndex(4);
var NM109_2420F = ec_DataHelper.GetValueByIndex(5);
var isReferringProvFound = ec_VariableHelper.GetVariable(&quot;isReferringProvFound&quot;);

if(isReferringProvFound!=&quot;true&quot;)
{	
	if(NM101_2420F==&quot;DN&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(0, lastName);
		ec_ResultHelper.ReportResultByIndex(1, firstName);
		ec_ResultHelper.ReportResultByIndex(2, middleName);
		ec_ResultHelper.ReportResultByIndex(3, suffix);
		ec_ResultHelper.ReportResultByIndex(4, NM109_2420F);
	}
}

