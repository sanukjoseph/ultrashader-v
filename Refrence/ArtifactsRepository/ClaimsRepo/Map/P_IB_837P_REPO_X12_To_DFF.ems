			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
var isDependentPresent = ec_VariableHelper.GetVariable(&quot;isDependentPresent&quot;);
var myRS = ec_VariableHelper.GetRecordSet(&quot;Details_2000B&quot;);
myRS.last();
var RS = myRS.getRow();
if (isDependentPresent == &quot;false&quot;)
{
	while(RS&gt;0)
	{
		var Fields = myRS.getFields();		
		{
	   	  	ec_ResultHelper.ReportResultByIndex(0,Fields[0]);
	   	  	ec_ResultHelper.ReportResultByIndex(1,Fields[1]);	
            ec_ResultHelper.ReportResultByIndex(2,Fields[2]);	
            ec_ResultHelper.ReportResultByIndex(3,Fields[3]);	
            ec_ResultHelper.ReportResultByIndex(4,Fields[4]);	
            ec_ResultHelper.ReportResultByIndex(5,Fields[5]);	
            ec_ResultHelper.ReportResultByIndex(6,Fields[6]);
