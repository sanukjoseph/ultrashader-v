		<Function ID="784" Name="Date_JS" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">31</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{deea6c3f-99bf-4a64-ac60-9636e3cad646}">Converting the date format CCYYMMDD to YYMMDD.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var hospiceStartDate=ec_DataHelper.GetValueByIndex(0);


var value = /[a-zA-Z!@#$%^&amp;*(),.?\&quot;:{}|&lt;&gt;]/;
if(hospiceStartDate!=&quot;&quot;){
	var flag = value.test(hospiceStartDate);
	
if(flag == false)
{
ec_ResultHelper.ReportResultByIndex(0,+hospiceStartDate.substring(0,4)+&quot;-&quot;+hospiceStartDate.substring(4,6)+&quot;-&quot;+hospiceStartDate.substring(6,8));


var hospiceEndDate=ec_DataHelper.GetValueByIndex(1);
if(hospiceEndDate!=&quot;&quot;){
	var flag = value.test(hospiceEndDate);
if(flag == false)
ec_ResultHelper.ReportResultByIndex(1,+hospiceEndDate.substring(0,4)+&quot;-&quot;+hospiceEndDate.substring(4,6)+&quot;-&quot;+hospiceEndDate.substring(6,8));
}

else if(hospiceEndDate==&quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(1,&quot;3000-01-01&quot;);
}
}
}
</Property>
			</Properties>
