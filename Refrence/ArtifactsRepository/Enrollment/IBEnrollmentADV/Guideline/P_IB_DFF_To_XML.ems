		<Function ID="219" Name="PLN_GRP" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">21</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{deea6c3f-99bf-4a64-ac60-9636e3cad646}">Creating and declaring the variable and checking the condtion if transcation type is PLN and GRP,
populating the group id.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var trxType = ec_VariableHelper.GetVariable(&quot;Tr_Type&quot;);
var groupID = ec_DataHelper.GetValueByIndex(0);
var grpID = groupID.substring(0,6);
if( trxType == 'PLN' || trxType == 'GRP')
{
	ec_ResultHelper.ReportResultByIndex(0,grpID);
}
</Property>
			</Properties>
