		<Function ID="970" Name="JavaScript_Member_Billing_Address" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">5</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var Billing_Adress1 = ec_DataHelper.GetValueByName(&quot;value1&quot;);
var Billing_Adress2 = ec_DataHelper.GetValueByName(&quot;value2&quot;);
var Billing_Adress3 = ec_DataHelper.GetValueByName(&quot;value3&quot;);
var Billing_CityName = ec_DataHelper.GetValueByName(&quot;value4&quot;);
var Billing_State = ec_DataHelper.GetValueByName(&quot;value5&quot;);
var Billing_Zip_Code = ec_DataHelper.GetValueByName(&quot;value6&quot;);
var Tr_Type = ec_VariableHelper.GetVariable(&quot;Tr_Type&quot;);

if(Tr_Type == &quot;DEM&quot; )
{
	ec_ResultHelper.ReportResultByIndex(0,Billing_Adress1);
	ec_ResultHelper.ReportResultByIndex(1,'IndividualAddressType');
	ec_ResultHelper.ReportResultByIndex(2,'10');
	ec_ResultHelper.ReportResultByIndex(3,Billing_Adress2);
	ec_ResultHelper.ReportResultByIndex(4,Billing_Adress3);
	ec_ResultHelper.ReportResultByIndex(5,Billing_CityName);
	ec_ResultHelper.ReportResultByIndex(6,Billing_State);
	ec_ResultHelper.ReportResultByIndex(7,Billing_Zip_Code);
}</Property>
			</Properties>
