			<Properties Category="GlobalUserNotes">
				<Property Name="{deea6c3f-99bf-4a64-ac60-9636e3cad646}">Converting the date format CCYYMMDD to YYMMDD.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var mcdStartDate=ec_DataHelper.GetValueByIndex(0);
var value = /[a-zA-Z!@#$%^&amp;*(),.?\&quot;:{}|&lt;&gt;]/;
if(mcdStartDate!=&quot;&quot;){
	var flag = value.test(mcdStartDate);
if(flag == false)
ec_ResultHelper.ReportResultByIndex(0,+mcdStartDate.substring(0,4)+&quot;-&quot;+mcdStartDate.substring(4,6)+&quot;-&quot;+mcdStartDate.substring(6,8));
}

var mcdEndDate=ec_DataHelper.GetValueByIndex(1);
if(mcdEndDate!=&quot;&quot;){
	var flag = value.test(mcdEndDate);
if(flag == false)
ec_ResultHelper.ReportResultByIndex(1,+mcdEndDate.substring(0,4)+&quot;-&quot;+mcdEndDate.substring(4,6)+&quot;-&quot;+mcdEndDate.substring(6,8));
}

</Property>
