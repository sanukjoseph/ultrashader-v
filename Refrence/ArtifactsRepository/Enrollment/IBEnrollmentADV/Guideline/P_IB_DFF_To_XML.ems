		<Function ID="819" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">24</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var TransType = ec_DataHelper.GetValueByIndex(0);
// Retrieving the record set or creating the recordset
var myRS1 = ec_VariableHelper.GetRecordSet(&quot;PCP_Details&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
var resArr1 = new Array();
if (TransType == &quot;PCP&quot;)
{
	for(i=0;i&lt;4;i++)
	{
		resArr1[i] = ec_DataHelper.GetValueByIndex(i);
	}
}
//Updating the newly inserted row with the values from the array
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;PCP_Details&quot;, myRS1, true);</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab24/XPos">128</Property>
				<Property Name="Tab24/YPos">-32</Property>
			</Properties>
			<ConnectionPoints>
