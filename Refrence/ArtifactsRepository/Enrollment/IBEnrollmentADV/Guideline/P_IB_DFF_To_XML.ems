				<Property Name="Parameters/ec_Script">var MemberAltPhone = ec_DataHelper.GetValueByIndex(0);
var Tr_Type = ec_VariableHelper.GetVariable(&quot;Tr_Type&quot;);

if(Tr_Type == &quot;DEM&quot;)

{
  if(MemberAltPhone.length == 10)
	{
		ec_ResultHelper.ReportResultByIndex(0, MemberAltPhone.substr(0,3));
		ec_ResultHelper.ReportResultByIndex(1, MemberAltPhone.substr(3,9));
		ec_ResultHelper.ReportResultByIndex(2, &quot;IndividualPhoneType&quot;);
		ec_ResultHelper.ReportResultByIndex(3, &quot;AP&quot;);
