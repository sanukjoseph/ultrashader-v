		<Function ID="665" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">17</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var trType = ec_VariableHelper.GetVariable(&quot;Tr_Type&quot;);
var FlgDisabled = ec_VariableHelper.GetVariable(&quot;Disabled&quot;);

if(trType == &quot;FLG&quot;)
{
if (FlgDisabled === &quot;Y&quot;) {
    ec_ResultHelper.ReportResultByIndex(0, &quot;true&quot;);
} else if (FlgDisabled === &quot;N&quot;) {
    ec_ResultHelper.ReportResultByIndex(0, &quot;false&quot;);
} else if (FlgDisabled.includes(&quot;Y|N&quot;)) {
    ec_ResultHelper.ReportResultByIndex(0, &quot;true&quot;);
} else if (FlgDisabled.includes(&quot;N|Y&quot;)) {
    ec_ResultHelper.ReportResultByIndex(0, &quot;true&quot;);
}
}

 

</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab17/XPos">176</Property>
				<Property Name="Tab17/YPos">-48</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="3386" FP="_AP" Name="activation">
