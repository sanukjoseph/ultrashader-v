		<Function ID="536" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">16</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{deea6c3f-99bf-4a64-ac60-9636e3cad646}">Checking th etranscation type is eqaul to PLN
and print the result &quot;result1&quot;,conNo+PBPNo in combination.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var conNo=ec_VariableHelper.GetVariable(&quot;Con_No&quot;);
var PBPNo=ec_VariableHelper.GetVariable(&quot;PBP_No&quot;);
//var conNo=ec_DataHelper.GetValueByName(&quot;value1&quot;);
//var PBPNo=ec_DataHelper.GetValueByName(&quot;value2&quot;);

var Trn_Type=ec_VariableHelper.GetVariable(&quot;Tr_Type&quot;);

if(Trn_Type==&quot;PLN&quot;)
{
ec_ResultHelper.ReportResultByName(&quot;result1&quot;,conNo+PBPNo);
}</Property>
			</Properties>
