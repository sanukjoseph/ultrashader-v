		<Function ID="155" Name="SignatureDate" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">16</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{deea6c3f-99bf-4a64-ac60-9636e3cad646}">Changing the date format to CCYYMMDD to YYMMDD</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var date=ec_DataHelper.GetValueByIndex(0);
var value = /[a-zA-Z!@#$%^&amp;*(),.?\&quot;:{}|&lt;&gt;]/;
if(date!=&quot;&quot;){
	var flag = value.test(date);
if(flag == false)	
ec_ResultHelper.ReportResultByIndex(0,+date.substring(0,4)+&quot;-&quot;+date.substring(4,6)+&quot;-&quot;+date.substring(6,8));
}</Property>
			</Properties>
