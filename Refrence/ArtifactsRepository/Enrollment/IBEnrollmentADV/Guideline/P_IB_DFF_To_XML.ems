		<Function ID="871" Name="HP_Check" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">39</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var MemberHomePhone = ec_DataHelper.GetValueByIndex(0);
var Tr_Type = ec_VariableHelper.GetVariable(&quot;Tr_Type&quot;);

if(Tr_Type == &quot;DEM&quot;)

{
  if(MemberHomePhone.length == 10)
	{
		ec_ResultHelper.ReportResultByIndex(0, MemberHomePhone.substr(0,3));
		ec_ResultHelper.ReportResultByIndex(1, MemberHomePhone.substr(3,9));
		ec_ResultHelper.ReportResultByIndex(2, &quot;IndividualPhoneType&quot;);
		ec_ResultHelper.ReportResultByIndex(3, &quot;HP&quot;);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(0, MemberHomePhone);
		ec_ResultHelper.ReportResultByIndex(1, &quot;IndividualPhoneType&quot;);
		ec_ResultHelper.ReportResultByIndex(2, &quot;HP&quot;);
	}
}	</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab39/XPos">208</Property>
				<Property Name="Tab39/YPos">16</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="4103" FP="A" Pos="0" Name="value1">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="4104" FP="X" Pos="0" Name="result1"/>
				<ConnectionPoint ID="4105" FP="X" Pos="1" Name="result2"/>
				<ConnectionPoint ID="4106" FP="X" Pos="2" Name="result3"/>
				<ConnectionPoint ID="4107" FP="X" Pos="3" Name="result4"/>
			</ConnectionPoints>
		</Function>
