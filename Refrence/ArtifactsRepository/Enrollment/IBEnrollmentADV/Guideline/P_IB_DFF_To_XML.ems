		<Function ID="875" Name="FX_Check" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">39</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var FaxNo = ec_DataHelper.GetValueByIndex(0);
var Tr_Type = ec_VariableHelper.GetVariable(&quot;Tr_Type&quot;);

if(Tr_Type == &quot;DEM&quot;)

{
  if(FaxNo.length == 10)
	{
		ec_ResultHelper.ReportResultByIndex(0, FaxNo.substr(0,3));
		ec_ResultHelper.ReportResultByIndex(1, FaxNo.substr(3,9));
		ec_ResultHelper.ReportResultByIndex(2, &quot;IndividualPhoneType&quot;);
		ec_ResultHelper.ReportResultByIndex(3, &quot;FX&quot;);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(0, FaxNo);
		ec_ResultHelper.ReportResultByIndex(1, &quot;IndividualPhoneType&quot;);
		ec_ResultHelper.ReportResultByIndex(2, &quot;FX&quot;);
	}
}	</Property>
