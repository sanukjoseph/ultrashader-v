			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var recordId = ec_VariableHelper.GetVariable(&quot;recordId&quot;);
var PLN_Count = ec_VariableHelper.GetVariable(&quot;PLN_Count&quot;);
var unique = ec_VariableHelper.GetVariable(&quot;Unique&quot;);
