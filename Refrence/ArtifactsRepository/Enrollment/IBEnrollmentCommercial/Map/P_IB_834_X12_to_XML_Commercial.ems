		<Function ID="707" Name="JavaScript-Input LUI 1" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">10</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;lang&quot;);

var resArr = new Array();

for (var i = 0; i &lt; 2; i++)
{
  resArr [i] = ec_DataHelper.GetValueByIndex(i);// Getting the value by index and assigning it to the array	
}
// Inserting a new row into the record set
myRS.insertRow();
myRS.updateRow(resArr);// Updating the newly inserted row with the values from the array
ec_VariableHelper.SetRecordSet(&quot;lang&quot;, myRS, true);// Setting the updated record set in the variable &quot;Pay_To_Address_2010AB_2000B&quot;</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab10/XPos">80</Property>
				<Property Name="Tab10/YPos">0</Property>
			</Properties>
