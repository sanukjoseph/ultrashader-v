				<Property Name="BGSet">13</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var edieligibilitystartdate  = ec_VariableHelper.GetVariable(&quot;StartDate&quot;);
var edieligibilityenddate  = ec_VariableHelper.GetVariable(&quot;Enddate&quot;);
var broker = ec_VariableHelper.GetVariable(&quot;Broker&quot;);

if(broker == &quot;BO&quot; || broker == &quot;TV&quot;)
{
	ec_ResultHelper.ReportResultByIndex(0, edieligibilitystartdate);
	ec_ResultHelper.ReportResultByIndex(1, edieligibilityenddate);
	}</Property>
