		<Function ID="617" Name="JavaScript_MaintenanceReasonCode" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">4</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var maintenanceReasonCode = ec_DataHelper.GetValueByIndex(0);

if(maintenanceReasonCode==&quot;01&quot;)
ec_ResultHelper.ReportResultByIndex(0,&quot;1&quot;);
else if(maintenanceReasonCode==&quot;03&quot;)
ec_ResultHelper.ReportResultByIndex(0,&quot;3&quot;);
else if(maintenanceReasonCode==&quot;07&quot;)
ec_ResultHelper.ReportResultByIndex(0,&quot;7&quot;);
else
ec_ResultHelper.ReportResultByIndex(0,maintenanceReasonCode);</Property>
