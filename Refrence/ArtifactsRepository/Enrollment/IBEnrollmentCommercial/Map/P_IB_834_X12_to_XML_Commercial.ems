			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var ins04 = ec_VariableHelper.GetVariable(&quot;INS04&quot;);
var ins12 = ec_VariableHelper.GetVariable(&quot;INS12&quot;);
//var dtp = ec_VariableHelper.GetVariable(&quot;DTP_349&quot;);
var dod = ec_DataHelper.GetValueByIndex(0);
var YY = dod.substring(0,4);
var MM = dod.substring(4,6);
var DD = dod.substring(6,8);
if(ins04 == &quot;03&quot;)
{
	ec_ResultHelper.ReportByIndex(0,dateOfDeath);
	
}
//else if(ins012 == &quot;&quot;)
//{
//ec_ResultHelper.ReportByIndex(0,dateOfDeath);
