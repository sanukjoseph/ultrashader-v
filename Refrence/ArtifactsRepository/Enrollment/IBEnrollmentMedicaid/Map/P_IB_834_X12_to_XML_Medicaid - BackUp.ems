		<Function ID="325" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">14</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var qualifier = ec_DataHelper.GetValueByIndex(0);
var date = ec_DataHelper.GetValueByIndex(1);


if(qualifier == 'D8')
{
ec_ResultHelper.ReportResultByIndex(0, date.substr(0,8));

}
else if (qualifier == 'RD8')
{
	ec_ResultHelper.ReportResultByIndex(0, date.substr(0,8));
ec_ResultHelper.ReportResultByIndex(1, date.substr(9,8));
}</Property>
			</Properties>
