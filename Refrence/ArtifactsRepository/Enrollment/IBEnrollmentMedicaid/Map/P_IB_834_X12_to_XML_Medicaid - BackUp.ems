		<Function ID="522" Name="JavaScript_2200_DisabilityInfo_Input" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">6</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;DisabilityInfo&quot;);

var resArr = new Array();

//Assigns the input values to the respective indices of the array &quot;resArr&quot;

   
	
			 resArr[0] = ec_DataHelper.GetValueByIndex(0);
			 if(ec_DataHelper.GetValueByIndex(1)==&quot;360&quot;)
			 resArr[1] = ec_DataHelper.GetValueByIndex(2);
			 
	

myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;DisabilityInfo&quot;, myRS, true);</Property>
