		<Function ID="387" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">4</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var ssnQualifier = ec_DataHelper.GetValueByIndex(0);

 

var ssnValue = ec_DataHelper.GetValueByIndex(1);

 


if(ssnQualifier == &quot;34&quot;)
{
ec_ResultHelper.ReportResultByIndex(0, ssnValue.substr(0,3) + &quot;-&quot; + ssnValue.substr(3,2) + &quot;-&quot;+ ssnValue.substr(5));
}</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab4/XPos">64</Property>
				<Property Name="Tab4/YPos">0</Property>
			</Properties>
