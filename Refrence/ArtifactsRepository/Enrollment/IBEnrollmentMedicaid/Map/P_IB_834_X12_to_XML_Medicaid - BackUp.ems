				<Property Name="Parameters/ec_Script">var sub_Lname = ec_VariableHelper.GetVariable(&quot;sub_Lname&quot;);
var sub_Fname = ec_VariableHelper.GetVariable(&quot;sub_Fname&quot;);
var sub_gndr = ec_VariableHelper.GetVariable(&quot;sub_gndr&quot;);
