		<Function ID="972" Name="2310 Mapping" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">10</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var NM101_2310 = ec_VariableHelper.GetVariable(&quot;NM101_2310&quot;);
var NM102_2310 = ec_VariableHelper.GetVariable(&quot;NM102_2310&quot;);

var NM103_2310 = ec_VariableHelper.GetVariable(&quot;NM103_2310&quot;);
var NM104_2310 = ec_VariableHelper.GetVariable(&quot;NM104_2310&quot;);

var NM108_2310 = ec_VariableHelper.GetVariable(&quot;NM108_2310&quot;);
var NM109_2310 = ec_VariableHelper.GetVariable(&quot;NM109_2310&quot;);

var Plan_BenefitBeginDate_348 = ec_VariableHelper.GetVariable(&quot;Plan_BenefitBeginDate_348&quot;);
var Plan_BenefitEndDate_349 = ec_VariableHelper.GetVariable(&quot;Plan_BenefitEndDate_349&quot;);


if(NM101_2310 == &quot;P3&quot;)
{
	
	
	if(NM102_2310 == &quot;1&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(0,&quot;PCP&quot;);
		if(Plan_BenefitBeginDate_348 != &quot;&quot;)
		ec_ResultHelper.ReportResultByIndex(1,Plan_BenefitBeginDate_348.substr(0,4)+'-'+Plan_BenefitBeginDate_348.substr(4,2)+'-'+Plan_BenefitBeginDate_348.substr(6,2));
		if(Plan_BenefitEndDate_349 != &quot;&quot;)
		ec_ResultHelper.ReportResultByIndex(2,Plan_BenefitEndDate_349.substr(0,4)+'-'+Plan_BenefitEndDate_349.substr(4,2)+'-'+Plan_BenefitEndDate_349.substr(6,2));
		ec_ResultHelper.ReportResultByIndex(3,NM104_2310);
		ec_ResultHelper.ReportResultByIndex(4,NM103_2310);
		if(NM108_2310 == &quot;SV&quot;)
		{
			ec_ResultHelper.ReportResultByIndex(5,NM109_2310);
		}
		
	}
	else if (NM102_2310 == &quot;2&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(0,&quot;PCP&quot;);
		ec_ResultHelper.ReportResultByIndex(1,Plan_BenefitBeginDate_348.substr(0,4)+'-'+Plan_BenefitBeginDate_348.substr(4,2)+'-'+Plan_BenefitBeginDate_348.substr(6,2));
		ec_ResultHelper.ReportResultByIndex(2,Plan_BenefitEndDate_349.substr(0,4)+'-'+Plan_BenefitEndDate_349.substr(4,2)+'-'+Plan_BenefitEndDate_349.substr(6,2));
		
		ec_ResultHelper.ReportResultByIndex(6,NM103_2310);
		if(NM108_2310 == &quot;SV&quot;)
		{
			ec_ResultHelper.ReportResultByIndex(7,NM109_2310);
		}
		
	}
	
}
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab10/XPos">192</Property>
				<Property Name="Tab10/YPos">-48</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="3982" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
