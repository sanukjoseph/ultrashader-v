		<Function ID="201" Name="JavaScript_2100A_Member_Malling_Address" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">15</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{e5beff85-7b5b-48b0-94dd-138b03f464be}">1.Storging the value of 2100A and 2100C using the change variabale.
2.If data is not present in 2100C back filling from 2100A</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var n3012100A = ec_VariableHelper.GetVariable(&quot;N3_01_2100A&quot;);
var n3022100A = ec_VariableHelper.GetVariable(&quot;N3_02_2100A&quot;);
var n4012100A = ec_VariableHelper.GetVariable(&quot;N4_01_2100A&quot;);
var n4022100A = ec_VariableHelper.GetVariable(&quot;N4_02_2100A&quot;);
var n4032100A = ec_VariableHelper.GetVariable(&quot;N4_03_2100A&quot;);
var n4042100A = ec_VariableHelper.GetVariable(&quot;N4_04_2100A&quot;);
var Member_Mail_ID_2100A = ec_VariableHelper.GetVariable(&quot;Member_Mail_ID_2100A&quot;);
 
//if(isSubscriber == &quot;Y&quot;) 
//{
 
//if(n3012100A.length &gt; 0 &amp;&amp; n3012100C.length &gt; 0)// &amp;&amp; (n3012100A.toUpperCase() != n3012100C.toUpperCase() || n3022100A.toUpperCase() != n3022100C.toUpperCase()) 
//{
	if(n3012100A.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(0,n3012100A);
	}
	if(n3022100A.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(1,n3022100A);
	}
	if(n4012100A.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(2,n4012100A);
	}
	if(n4022100A.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(3,n4022100A);
	}
	if(n4032100A.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(4,n4032100A);
	}
	if(n4042100A.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(5,n4042100A);
	}
	
	
	if(Member_Mail_ID_2100A.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(6,Member_Mail_ID_2100A);
	}</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab15/XPos">144</Property>
				<Property Name="Tab15/YPos">-336</Property>
				<Property Name="Tab1/XPos">-48</Property>
				<Property Name="Tab1/YPos">-288</Property>
				<Property Name="Tab4/XPos">-12</Property>
				<Property Name="Tab4/YPos">-288</Property>
				<Property Name="Tab6/XPos">-80</Property>
				<Property Name="Tab6/YPos">-288</Property>
				<Property Name="Tab14/XPos">-12</Property>
				<Property Name="Tab14/YPos">-288</Property>
				<Property Name="Tab16/XPos">-16</Property>
				<Property Name="Tab16/YPos">-288</Property>
				<Property Name="Tab7/XPos">-12</Property>
				<Property Name="Tab7/YPos">-288</Property>
				<Property Name="Tab8/XPos">-16</Property>
				<Property Name="Tab8/YPos">-288</Property>
				<Property Name="Tab9/XPos">-32</Property>
				<Property Name="Tab9/YPos">-288</Property>
				<Property Name="Tab10/XPos">-12</Property>
				<Property Name="Tab10/YPos">-308</Property>
