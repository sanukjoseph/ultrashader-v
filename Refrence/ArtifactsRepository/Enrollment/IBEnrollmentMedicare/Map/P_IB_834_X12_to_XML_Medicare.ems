				<Property Name="Parameters/ec_Script">var sub_Lname = ec_VariableHelper.GetVariable(&quot;sub_Lname&quot;);
var sub_Fname = ec_VariableHelper.GetVariable(&quot;sub_Fname&quot;);
var sub_gndr = ec_VariableHelper.GetVariable(&quot;sub_gndr&quot;);
var sub_txid = ec_VariableHelper.GetVariable(&quot;sub_txid&quot;);
var sub_dob = ec_VariableHelper.GetVariable(&quot;sub_dob&quot;);
var sub_txid = ec_VariableHelper.GetVariable(&quot;sub_txid&quot;);


ec_ResultHelper.ReportResultByIndex(0,sub_Lname);
ec_ResultHelper.ReportResultByIndex(1,sub_Fname);
ec_ResultHelper.ReportResultByIndex(2,sub_gndr);
ec_ResultHelper.ReportResultByIndex(3,sub_dob);
ec_ResultHelper.ReportResultByIndex(4,sub_txid);

</Property>
			</Properties>
