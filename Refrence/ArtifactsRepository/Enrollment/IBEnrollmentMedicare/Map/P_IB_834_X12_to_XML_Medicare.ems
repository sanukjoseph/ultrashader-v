		<Function ID="1073" Name="Qualifier_List_Mapping" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">36</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var Subscriber_Identifier_REF_OF  = ec_VariableHelper.GetVariable(&quot;Subscriber_Identifier_REF_OF&quot;);	
var Member_Policy_Number_IL_2000  = ec_VariableHelper.GetVariable(&quot;Member_Policy_Number_IL_2000&quot;);
var Member_Supplemental_ID_2000  = ec_VariableHelper.GetVariable(&quot;Member_Supplemental_ID_2000&quot;);
var MTC  = ec_VariableHelper.GetVariable(&quot;MTC&quot;);


//var StartDateQualifierList = ec_DataHelper.GetValueByIndex(0);
var asOfDate = ec_VariableHelper.GetVariable(&quot;asOfDate&quot;);
var asOfDate_025 = ec_VariableHelper.GetVariable(&quot;asOfDate_025&quot;);




if(Subscriber_Identifier_REF_OF != &quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(0, &quot;0F&quot;);
	ec_ResultHelper.ReportResultByIndex(1, Subscriber_Identifier_REF_OF);
	if(MTC == &quot;025&quot;)
	{
		//ec_ResultHelper.println(&quot;MTC Member_Supplemental_ID_F6&quot;+MTC +&quot;-&quot;+Member_Supplemental_ID_F6);
	ec_ResultHelper.ReportResultByIndex(2, asOfDate_025);
	}
	else if(MTC != &quot;024&quot;)
	ec_ResultHelper.ReportResultByIndex(2, asOfDate);
	if(MTC == &quot;024&quot;)
	{
		//ec_ResultHelper.println(&quot;MTC Member_Supplemental_ID_F6&quot;+MTC +&quot;-&quot;+Member_Supplemental_ID_F6);
	ec_ResultHelper.ReportResultByIndex(3, asOfDate);
	}
	
}
if(Member_Policy_Number_IL_2000 != &quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(4, &quot;1L&quot;);
	ec_ResultHelper.ReportResultByIndex(5, Member_Policy_Number_IL_2000);
	if(MTC == &quot;025&quot;)
	{
		//ec_ResultHelper.println(&quot;Member_Policy_Number_IL_2000&quot;+MTC +&quot;-&quot;+Member_Policy_Number_IL_2000);
		ec_ResultHelper.ReportResultByIndex(6, asOfDate_025);
	}
	else if(MTC != &quot;024&quot;)
		ec_ResultHelper.ReportResultByIndex(6, asOfDate);
	if(MTC == &quot;024&quot;)
	{
		//ec_ResultHelper.println(&quot;Member_Policy_Number_IL_2000&quot;+MTC +&quot;-&quot;+Member_Policy_Number_IL_2000);
		ec_ResultHelper.ReportResultByIndex(7, asOfDate);
	}
	
}
	
var SupplementalArrayElements = new Array();
var SupplementalArrayElementsSplit = new Array();

if(Member_Supplemental_ID_2000 != &quot;&quot;)
{
	SupplementalArrayElements = Member_Supplemental_ID_2000.split(&quot;-&quot;);
}
for(var i=0;i&lt;SupplementalArrayElements.length;i++)
{
	
	SupplementalArrayElementsSplit = SupplementalArrayElements[i].split(&quot;,&quot;);
	ec_ResultHelper.ReportResultByIndex(8, SupplementalArrayElementsSplit[0]);
	ec_ResultHelper.ReportResultByIndex(9, SupplementalArrayElementsSplit[1]);
	if(MTC == &quot;025&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(10, asOfDate_025);
	}
	else if(MTC!=&quot;024&quot;)
	ec_ResultHelper.ReportResultByIndex(10, asOfDate);
	if(MTC == &quot;024&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(11, asOfDate);
	}
	
	ec_ResultHelper.Send();
		
}

</Property>
