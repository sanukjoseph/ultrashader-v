		<Function ID="202" Name="JavaScript_2100c_N4_04" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">15</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{e5beff85-7b5b-48b0-94dd-138b03f464be}">1.Spliting the values (0 to 5)and displaying in the Zip
2.Spliting the values (5 to 9)and displaying in the Zip extention code.


1. /enrollment/member/correspondenceAddress/postalAddress/zipCode

2./enrollment/member/correspondenceAddress/postalAddress/zipExtensionCode</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">
var n4032100A = ec_DataHelper.GetValueByIndex(0);

if(n4032100A.length &gt; 0)
{
	var zip = n4032100A.substring(0,5);
	var zipExtension = n4032100A.substring(5,9);
		
	ec_ResultHelper.ReportResultByIndex(0,zip);
	ec_ResultHelper.ReportResultByIndex(1,zipExtension);
}
/*else
{
	var zip = n4032100A.substring(0,5);
	var zipExtension = n4032100A.substring(5,9);
		
	ec_ResultHelper.ReportResultByIndex(4,zip);
	ec_ResultHelper.ReportResultByIndex(6,zipExtension);
}*/</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab15/XPos">368</Property>
