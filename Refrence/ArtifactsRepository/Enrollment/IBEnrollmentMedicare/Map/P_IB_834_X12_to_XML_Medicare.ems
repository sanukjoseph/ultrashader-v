		<Function ID="609" Name="JavaScript_2100C_Member_Malling_Address" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">13</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{e5beff85-7b5b-48b0-94dd-138b03f464be}">1.Storging the value of 2100A and 2100C using the change variabale.
2.If data is not present in 2100C back filling from 2100A</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">

var n3012100C = ec_VariableHelper.GetVariable(&quot;N3_01_2100C&quot;);
var n3022100C = ec_VariableHelper.GetVariable(&quot;N3_02_2100C&quot;);
var n4012100C = ec_VariableHelper.GetVariable(&quot;N4_01_2100C&quot;);
var n4022100C = ec_VariableHelper.GetVariable(&quot;N4_02_2100C&quot;);
var n4032100C = ec_VariableHelper.GetVariable(&quot;N4_03_2100C&quot;);
var n4042100C = ec_VariableHelper.GetVariable(&quot;N4_04_2100C&quot;);

var n3012100A = ec_VariableHelper.GetVariable(&quot;N3_01_2100A&quot;);
var n3022100A = ec_VariableHelper.GetVariable(&quot;N3_02_2100A&quot;);
var n4012100A = ec_VariableHelper.GetVariable(&quot;N4_01_2100A&quot;);
var n4022100A = ec_VariableHelper.GetVariable(&quot;N4_02_2100A&quot;);
var n4032100A = ec_VariableHelper.GetVariable(&quot;N4_03_2100A&quot;);
var n4062100A = ec_VariableHelper.GetVariable(&quot;N4_04_2100A&quot;);


//if(isSubscriber == &quot;Y&quot;) 
//{

//if(n3012100A.length &gt; 0 &amp;&amp; n3012100C.length &gt; 0)// &amp;&amp; (n3012100A.toUpperCase() != n3012100C.toUpperCase() || n3022100A.toUpperCase() != n3022100C.toUpperCase()) 
//{
	if(n3012100C.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(0,n3012100C);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(0,n3012100A);
	}
	
	if(n3022100C.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(1,n3022100C);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(1,n3022100A);
	}
	
	if(n4012100C.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(2,n4012100C);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(2,n4012100A);
	}
	
	if(n4022100C.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(3,n4022100C);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(3,n4022100A);
	}
	
	if(n4032100C.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(4,n4032100C);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(4,n4032100A);
	}
	if(n4042100C.length &gt; 0)
	{
		ec_ResultHelper.ReportResultByIndex(5,n4042100C);
	}
	else
	{
		ec_ResultHelper.ReportResultByIndex(5,n4062100A);
	}
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab13/XPos">64</Property>
				<Property Name="Tab13/YPos">-896</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="2762" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="2763" FP="A" Pos="0" Name="value1"/>
