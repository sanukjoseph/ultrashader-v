		<Function ID="1104" Name="JavaScript Input No Language Indicator" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">6</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS2 = ec_VariableHelper.GetRecordSet(&quot;lang2&quot;);

var resArr = new Array();

for (var i = 0; i &lt; 2; i++)
{
  resArr [i] = ec_DataHelper.GetValueByIndex(i);// Getting the value by index and assigning it to the array	
}
// Inserting a new row into the record set
myRS2.insertRow();
myRS2.updateRow(resArr);// Updating the newly inserted row with the values from the array
ec_VariableHelper.SetRecordSet(&quot;lang2&quot;, myRS2, true);// Setting the updated record set in the variable &quot;Pay_To_Address_2010AB_2000B&quot;</Property>
			</Properties>
