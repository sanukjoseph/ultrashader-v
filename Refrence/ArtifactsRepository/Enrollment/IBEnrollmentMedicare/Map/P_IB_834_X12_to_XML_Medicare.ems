			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var INS_06_01 = ec_VariableHelper.GetVariable(&quot;INS_06_01_20000&quot;);
var REF01     = ec_VariableHelper.GetVariable(&quot;REF01__2000&quot;);
var DTP01     = ec_VariableHelper.GetVariable(&quot;DTP01__2000&quot;);
var DTP03     = ec_VariableHelper.GetVariable(&quot;DTP03__2000&quot;);
//var REF01 = ec_DataHelper.GetValueByName(&quot;value1&quot;);
//ec_ResultHelper.println(INS_06_01);
//ec_ResultHelper.println(REF01);
//ec_ResultHelper.println(DTP01);
//ec_ResultHelper.println(DTP03);

if(INS_06_01 == &quot;C&quot; &amp;&amp; REF01 == &quot;F6&quot; &amp;&amp; DTP01 == &quot;339&quot;)
	{
	 ec_ResultHelper.ReportResultByIndex(0,DTP03);
	}
	
else if(INS_06_01 == &quot;A&quot; &amp;&amp; REF01 == &quot;F6&quot; &amp;&amp; DTP01 == &quot;339&quot;)
	{
	 ec_ResultHelper.ReportResultByIndex(0,DTP03);
	}</Property>
