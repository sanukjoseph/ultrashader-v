		<Function ID="667" Name="JavaScript_2100G_Input" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">15</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">Get the member details in the recordset RS_2100G.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var memberName = new Array();
myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2100G&quot;);

 resArr = new Array();
 
 //Assigns input valyes to resArr array
 for(i=0;i&lt;15;i++)
 
 	{
 	resArr[i] = ec_DataHelper.GetValueByIndex(i);
 	}
 
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;RS_2100G&quot;, myRS, true);</Property>
			</Properties>
