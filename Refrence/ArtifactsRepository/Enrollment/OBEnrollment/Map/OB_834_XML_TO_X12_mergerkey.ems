				<Property Name="Parameters/ec_Script">var myRS = ec_VariableHelper.GetRecordSet(&quot;RS_OtherResponsibility_2100F&quot;);
var Rendering = new Array();

for (var i = 0; i &lt; 2; i++) 
{
	Rendering[i] = ec_DataHelper.GetValueByIndex(i);
}	

myRS.insertRow();
myRS.updateRow(Rendering);
ec_VariableHelper.SetRecordSet(&quot;RS_OtherResponsibility_2100F&quot;, myRS, true);



	</Property>
