		<Function ID="1048" Name="JS_checking_with_same_date" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">35</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var myRS = ec_VariableHelper.GetRecordSet(&quot;RS_MedicareHICN&quot;);
myRS.last();
var RS1 = myRS.getRow();

while (RS1 &gt; 0) {
    var Fields = myRS.getFields();
    
    // Ensure that Fields array has enough elements to avoid out-of-bounds errors
    if (Fields &amp;&amp; Fields.length &gt;= 9) {
        // Check the condition for fields
        if ((Fields[0] != &quot;&quot;) &amp;&amp; (Fields[1] != &quot;&quot;) &amp;&amp; (Fields[2] != &quot;&quot;)) {
            // Report results if the condition is satisfied
            ec_ResultHelper.ReportResultByIndex(0, Fields[0]);
            ec_ResultHelper.ReportResultByIndex(1, Fields[1]);
            ec_ResultHelper.ReportResultByIndex(2, Fields[2]);
            ec_ResultHelper.ReportResultByIndex(3, Fields[3]);
            ec_ResultHelper.ReportResultByIndex(4, Fields[4]);
            ec_ResultHelper.ReportResultByIndex(5, Fields[5]);
            ec_ResultHelper.ReportResultByIndex(6, Fields[6]);
            ec_ResultHelper.ReportResultByIndex(7, Fields[7]);
            ec_ResultHelper.ReportResultByIndex(8, Fields[8]);
        }
    }
    
    // Move to the previous row
    myRS.previous();
    RS1 = myRS.getRow();
}
