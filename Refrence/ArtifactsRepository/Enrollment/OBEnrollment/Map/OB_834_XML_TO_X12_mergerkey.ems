		<Function ID="965" Name="RS_Per_2100F" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">33</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var otherRespRecordSet = ec_VariableHelper.GetRecordSet(&quot;RS_OtherResponsibility_2100F&quot;);
var isMemberSubscriber = ec_VariableHelper.GetVariable(&quot;MemberIsSubscriber&quot;);
otherRespRecordSet.last(); // Move the cursor to the last record in the recordset
var mainRecord = otherRespRecordSet.getRow(); // Get the current row of the recordset

while (mainRecord &gt; 0) {
    var otherRespFields = otherRespRecordSet.getFields();
    var perRecordSet = ec_VariableHelper.GetRecordSet(&quot;RS_PER_2100F&quot;);
    perRecordSet.last(); // Move the cursor to the last record in the PER recordset

    var perRecord = perRecordSet.getRow(); // Get the current row of the PER recordset
    while (perRecord &gt; 0) {
        var perFields = perRecordSet.getFields();

        if (otherRespFields[0] == &quot;ResponsibilityTypeCode&quot; &amp;&amp; otherRespFields[1] == &quot;1&quot; &amp;&amp; isMemberSubscriber ==&quot;false&quot;) {
            if (perFields[2] == &quot;TE&quot;) {
                ec_ResultHelper.ReportResultByIndex(0, perFields[0] + perFields[1]);
            } else if (perFields[2] == &quot;HP&quot;) {
                ec_ResultHelper.ReportResultByIndex(1, perFields[0] + perFields[1]);
            } else if (perFields[2] == &quot;WP&quot;) {
                ec_ResultHelper.ReportResultByIndex(2, perFields[0] + perFields[1]);
            } else if (perFields[2] == &quot;AP&quot;) {
                ec_ResultHelper.ReportResultByIndex(3, perFields[0] + perFields[1]);
            } else if (perFields[2] == &quot;FX&quot;) {
                ec_ResultHelper.ReportResultByIndex(4, perFields[0] + perFields[1]);
            } else if (perFields[2] == &quot;EX&quot;) {
                ec_ResultHelper.ReportResultByIndex(5, perFields[0] + perFields[1]);
            } else if (perFields[2] == &quot;BN&quot;) {
                ec_ResultHelper.ReportResultByIndex(6, perFields[0] + perFields[1]);
            } else if (perFields[2] == &quot;CP&quot;) {
                ec_ResultHelper.ReportResultByIndex(7, perFields[0] + perFields[1]);
            }
        }

        ec_ResultHelper.Send();
        perRecordSet.previous(); // Move the cursor to the previous row in the PER result set
        perRecord = perRecordSet.getRow();
    }

    ec_ResultHelper.Send();
    otherRespRecordSet.deleteRow(); // Delete the current row from the main recordset
    otherRespRecordSet.last(); // Move the cursor to the last row in the main recordset
    mainRecord = otherRespRecordSet.getRow(); // Get the current row in the main recordset
}
</Property>
