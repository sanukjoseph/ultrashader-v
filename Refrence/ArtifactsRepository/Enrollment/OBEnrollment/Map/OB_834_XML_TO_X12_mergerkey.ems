		<Function ID="1127" Name="JavaScript_2000REF_23_Output" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">40</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var myRS = ec_VariableHelper.GetRecordSet(&quot;RS_SupplementalId_23&quot;);
var records = [];

// Step 1: Iterate through the recordset and collect all rows
myRS.last();
var RS = myRS.getRow();

while (RS &gt; 0) {
    var Fields = myRS.getFields();

    // Store fields with their values
    records.push([
        Fields[0], // Index 0
        Fields[1], // Index 1
        Fields[2], // Index 2
        Fields[3]  // Index 3
    ]);

    myRS.previous();
    RS = myRS.getRow();
}

// Step 2: Group records by 0th index
var groupedRecords = {};

for (var i = 0; i &lt; records.length; i++) {
    var record = records[i];
    var key = record[0]; // 0th index

    if (!groupedRecords[key]) {
        groupedRecords[key] = [];
    }

    groupedRecords[key].push(record);
}

// Step 3: Process each group and pick the record with highest 4th or 3rd index
var finalResult;

for (var key in groupedRecords) {
    var group = groupedRecords[key];
    var maxRecord = null;
    var maxValue = null;
    var using3rdIndex = true;

    for (var j = 0; j &lt; group.length; j++) {
        var record = group[j];
        var third = record[2];
        var fourth = record[3];

        if (fourth !== &quot;&quot;) {
            if (maxValue === null || fourth &gt; maxValue) {
                maxValue = fourth;
                maxRecord = record;
                using3rdIndex = false;
            }
        } else {
            if (maxValue === null || third &gt; maxValue) {
                maxValue = third;
                maxRecord = record;
                using3rdIndex = true;
            }
        }
    }

    // If finalResult is not set yet or current record has a later value, update
    if (!finalResult || maxValue &gt; (using3rdIndex ? finalResult[2] : finalResult[3])) {
        finalResult = maxRecord;
    }
}

// Step 4: Report final result
if (finalResult) {
    ec_ResultHelper.ReportResultByIndex(0, finalResult[0]); // codeEntry
    ec_ResultHelper.ReportResultByIndex(1, finalResult[1]); // value
}
</Property>
