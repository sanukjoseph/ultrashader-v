			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">Concatenate HF834 with the current date.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var TRANSID = ec_DataHelper.GetValueByIndex(0);
var SYSDATE = ec_DataHelper.GetValueByIndex(1);

if (TRANSID != &quot;&quot; || SYSDATE != &quot;&quot;) 
{
	ec_ResultHelper.ReportResultByIndex(0, TRANSID + &quot;.&quot; + SYSDATE.substr(2,2)+SYSDATE.substr(4,2)+SYSDATE.substr(6,2));
}



