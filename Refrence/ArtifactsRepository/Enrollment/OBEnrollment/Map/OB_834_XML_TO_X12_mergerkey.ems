		<Function ID="146" Name="JavaScript - LUI mapping" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">7</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var Primary_Lang = ec_DataHelper.GetValueByIndex(0);
var Lang_Code = ec_DataHelper.GetValueByIndex(1);
var Native_Lang = ec_DataHelper.GetValueByIndex(2);

if (Lang_Code != &quot;&quot;){
	
	if (Primary_Lang == &quot;true&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;LE&quot;);
	ec_ResultHelper.ReportResultByIndex(1, Lang_Code);
	ec_ResultHelper.ReportResultByIndex(2, &quot;7&quot;);	
	}
	 if (Native_Lang == &quot;true&quot;){
	ec_ResultHelper.ReportResultByIndex(3, &quot;LE&quot;);
	ec_ResultHelper.ReportResultByIndex(4, Lang_Code);
	ec_ResultHelper.ReportResultByIndex(5, &quot;6&quot;);	
	 }
	 
	if(Primary_Lang==&quot;&quot; &amp;&amp;Native_Lang==&quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(6, &quot;LE&quot;);
	ec_ResultHelper.ReportResultByIndex(7, Lang_Code);}
}</Property>
			</Properties>
