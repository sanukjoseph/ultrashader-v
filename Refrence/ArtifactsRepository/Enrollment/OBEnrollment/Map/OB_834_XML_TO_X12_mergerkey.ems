        Fields[0], // Index 0
        Fields[1], // Index 1
        Fields[2], // Index 2
        Fields[3]  // Index 3
    ]);

    myRS.previous();
    RS = myRS.getRow();
}

// Step 2: Group records by 0th index
var groupedRecords = {};

for (var i = 0; i &lt; records.length; i++) {
    var record = records[i];
    var key = record[0]; // 0th index

    if (!groupedRecords[key]) {
        groupedRecords[key] = [];
    }

    groupedRecords[key].push(record);
}

// Step 3: Process each group and pick the record with highest 4th or 3rd index
var finalResult;

for (var key in groupedRecords) {
    var group = groupedRecords[key];
    var maxRecord = null;
    var maxValue = null;
    var using3rdIndex = true;

    for (var j = 0; j &lt; group.length; j++) {
        var record = group[j];
        var third = record[2];
        var fourth = record[3];

        if (fourth !== &quot;&quot;) {
            if (maxValue === null || fourth &gt; maxValue) {
                maxValue = fourth;
                maxRecord = record;
                using3rdIndex = false;
