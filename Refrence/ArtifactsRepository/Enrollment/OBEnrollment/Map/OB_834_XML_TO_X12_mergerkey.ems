		<Function ID="710" Name="JavaScript_2310_PCP_Input" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">13</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values and assign it to  myRS 
 myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2310_PCP&quot;);
 var providerRoleType = ec_VariableHelper.GetVariable(&quot;ProviderRoleType&quot;)
// Get the recordset  values to the array Fields 
Fields = myRS.getFields();
 if(providerRoleType=='1')
 {
//Report result to respective indexes
for(var i = 0; i &lt; 3; i++)
{
	Fields[i] = ec_DataHelper.GetValueByIndex(i);
}
//Update the recorset with the values of the array 'resArr'
myRS.insertRow();
myRS.updateRow(Fields);
ec_VariableHelper.SetRecordSet(&quot;RS_2310_PCP&quot;, myRS, true);
 }</Property>
