		<Function ID="174" Name="JavaScript_CustodialParent_CommunicationNumber_Output" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">11</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">The script null checks for phone numbers and maps the corresponding code entry value and phone number.
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var Email_2100F_PER = ec_VariableHelper.GetVariable(&quot;Email_2100F_PER&quot;);
var Custodial_Phone_HP = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_HP&quot;);
var Custodial_Phone_TE = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_TE&quot;);
var Custodial_Phone_WP = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_WP&quot;);
var Custodial_Phone_AP = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_AP&quot;);
var Custodial_Phone_FX = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_FX&quot;);
var Custodial_Phone_EX = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_EX&quot;);
var Custodial_Phone_BN = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_BN&quot;);
var Custodial_Phone_CP = ec_VariableHelper.GetVariable(&quot;Custodial_Phone_CP&quot;);
var MemberIsSubscriber = ec_VariableHelper.GetVariable(&quot;MemberIsSubscriber&quot;);

var CustodialParent_CodeEntry = ec_VariableHelper.GetVariable(&quot;ResponsiblePerson_CodeEntry&quot;);
var CustodialParent_CodeSetName = ec_VariableHelper.GetVariable(&quot;ResponsiblePerson_CodeSetName&quot;);
var CustodialParentCount = ec_VariableHelper.GetVariable(&quot;CustodialParentCount&quot;);

var flag_EM = &quot;N&quot;;
var flag_TE = &quot;N&quot;;
var flag_HP = &quot;N&quot;;
var flag_WP = &quot;N&quot;;
var flag_AP = &quot;N&quot;;
var flag_FX = &quot;N&quot;;
var flag_EX = &quot;N&quot;;
var flag_BN = &quot;N&quot;;
var flag_CP = &quot;N&quot;;

if(MemberIsSubscriber==&quot;false&quot;){
    if (Email_2100F_PER != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;EM&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Email_2100F_PER);
        flag_EM = &quot;Y&quot;;
    } else if (Custodial_Phone_TE != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;TE&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_TE);
        flag_TE = &quot;Y&quot;;
    } else if (Custodial_Phone_HP != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;HP&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_HP);
        flag_HP = &quot;Y&quot;;
    } else if (Custodial_Phone_WP != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;WP&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_WP);
        flag_WP = &quot;Y&quot;;
    } else if (Custodial_Phone_AP != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;AP&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_AP);
        flag_AP = &quot;Y&quot;;
    } else if (Custodial_Phone_FX != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;FX&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_FX);
        flag_FX = &quot;Y&quot;;
    } else if (Custodial_Phone_EX != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;EX&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_EX);
        flag_EX = &quot;Y&quot;;
    } else if (Custodial_Phone_BN != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;BN&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_BN);
        flag_BN = &quot;Y&quot;;
    } else if (Custodial_Phone_CP != &quot;&quot;) {
        ec_ResultHelper.ReportResultByIndex(0, &quot;CP&quot;);
        ec_ResultHelper.ReportResultByIndex(1, Custodial_Phone_CP);
        flag_CP = &quot;Y&quot;;
    }

    if (Email_2100F_PER != &quot;&quot; &amp;&amp; flag_EM == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;EM&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Email_2100F_PER);
        flag_EM = &quot;Y&quot;;
    } else if (Custodial_Phone_TE != &quot;&quot; &amp;&amp; flag_TE == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;TE&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_TE);
        flag_TE = &quot;Y&quot;;
    } else if (Custodial_Phone_HP != &quot;&quot; &amp;&amp; flag_HP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;HP&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_HP);
        flag_HP = &quot;Y&quot;;
    } else if (Custodial_Phone_WP != &quot;&quot; &amp;&amp; flag_WP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;WP&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_WP);
        flag_WP = &quot;Y&quot;;
    } else if (Custodial_Phone_AP != &quot;&quot; &amp;&amp; flag_AP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;AP&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_AP);
        flag_AP = &quot;Y&quot;;
    } else if (Custodial_Phone_FX != &quot;&quot; &amp;&amp; flag_FX == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;FX&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_FX);
        flag_FX = &quot;Y&quot;;
    } else if (Custodial_Phone_EX != &quot;&quot; &amp;&amp; flag_EX == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;EX&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_EX);
        flag_EX = &quot;Y&quot;;
    } else if (Custodial_Phone_BN != &quot;&quot; &amp;&amp; flag_BN == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;BN&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_BN);
        flag_BN = &quot;Y&quot;;
    } else if (Custodial_Phone_CP != &quot;&quot; &amp;&amp; flag_CP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(2, &quot;CP&quot;);
        ec_ResultHelper.ReportResultByIndex(3, Custodial_Phone_CP);
        flag_CP = &quot;Y&quot;;
    }

    if (Email_2100F_PER != &quot;&quot; &amp;&amp; flag_EM == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;EM&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Email_2100F_PER);
        flag_EM = &quot;Y&quot;;
    } else if (Custodial_Phone_TE != &quot;&quot; &amp;&amp; flag_TE == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;TE&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_TE);
        flag_TE = &quot;Y&quot;;
    } else if (Custodial_Phone_HP != &quot;&quot; &amp;&amp; flag_HP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;HP&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_HP);
        flag_HP = &quot;Y&quot;;
    } else if (Custodial_Phone_WP != &quot;&quot; &amp;&amp; flag_WP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;WP&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_WP);
        flag_WP = &quot;Y&quot;;
    } else if (Custodial_Phone_AP != &quot;&quot; &amp;&amp; flag_AP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;AP&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_AP);
        flag_AP = &quot;Y&quot;;
    } else if (Custodial_Phone_FX != &quot;&quot; &amp;&amp; flag_FX == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;FX&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_FX);
        flag_FX = &quot;Y&quot;;
    } else if (Custodial_Phone_EX != &quot;&quot; &amp;&amp; flag_EX == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;EX&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_EX);
        flag_EX = &quot;Y&quot;;
    } else if (Custodial_Phone_BN != &quot;&quot; &amp;&amp; flag_BN == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;BN&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_BN);
        flag_BN = &quot;Y&quot;;
    } else if (Custodial_Phone_CP != &quot;&quot; &amp;&amp; flag_CP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;CP&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Custodial_Phone_CP);
        flag_CP = &quot;Y&quot;;
    }

    
        ec_ResultHelper.ReportResultByIndex(6, &quot;PQ&quot;);
        }
    

</Property>
