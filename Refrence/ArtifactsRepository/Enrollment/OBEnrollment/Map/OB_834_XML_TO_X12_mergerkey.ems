        ec_ResultHelper.ReportResultByIndex(5, Responsibleperson_Phone_WP);
        flag_WP = &quot;Y&quot;;
    } else if (Responsibleperson_Phone_AP != &quot;&quot; &amp;&amp; flag_AP == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;AP&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Responsibleperson_Phone_AP);
        flag_AP = &quot;Y&quot;;
    } else if (Responsibleperson_Phone_FX != &quot;&quot; &amp;&amp; flag_FX == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;FX&quot;);
        ec_ResultHelper.ReportResultByIndex(5, Responsibleperson_Phone_FX);
        flag_FX = &quot;Y&quot;;
    } else if (Responsibleperson_Phone_EX != &quot;&quot; &amp;&amp; flag_EX == &quot;N&quot;) {
        ec_ResultHelper.ReportResultByIndex(4, &quot;EX&quot;);
