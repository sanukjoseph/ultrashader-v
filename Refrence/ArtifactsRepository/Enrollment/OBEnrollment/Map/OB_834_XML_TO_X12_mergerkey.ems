		<Function ID="643" Name="JavaScript_MemberCommunicationNumber_Input" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">7</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">This script check for the communication qualiifers like ,&quot;TE&quot;,&quot;HP&quot;,&quot;WP&quot; and maps there corresponding communication number which is the combination of phone area code and phone number.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var CodeEntry = ec_DataHelper.GetValueByIndex(0);
var PhoneAreaCode = ec_DataHelper.GetValueByIndex(1);
var PhoneNumber = ec_DataHelper.GetValueByIndex(2);
var MemberPhysicalAddressCount = ec_VariableHelper.GetVariable(&quot;MemberPhysicalAddressCount&quot;);


if(MemberPhysicalAddressCount==1)
{
if (CodeEntry == &quot;TE&quot;) {
   ec_ResultHelper.ReportResultByIndex(0,  PhoneAreaCode + PhoneNumber );
} else if (CodeEntry == &quot;HP&quot;) {
     ec_ResultHelper.ReportResultByIndex(1,  PhoneAreaCode + PhoneNumber );
} else if (CodeEntry == &quot;WP&quot;) {
     ec_ResultHelper.ReportResultByIndex(2,  PhoneAreaCode + PhoneNumber );
}else if (CodeEntry == &quot;AP&quot;) {
   ec_ResultHelper.ReportResultByIndex(3,  PhoneAreaCode + PhoneNumber );
} else if (CodeEntry == &quot;FX&quot;) {
     ec_ResultHelper.ReportResultByIndex(4,  PhoneAreaCode + PhoneNumber );
} else if (CodeEntry == &quot;EX&quot;) {
     ec_ResultHelper.ReportResultByIndex(5,  PhoneAreaCode + PhoneNumber );
}else if (CodeEntry == &quot;BN&quot;) {
     ec_ResultHelper.ReportResultByIndex(6,  PhoneAreaCode + PhoneNumber );
} else if (CodeEntry == &quot;CP&quot;) {
     ec_ResultHelper.ReportResultByIndex(7,  PhoneAreaCode + PhoneNumber );
}
}

</Property>
			</Properties>
