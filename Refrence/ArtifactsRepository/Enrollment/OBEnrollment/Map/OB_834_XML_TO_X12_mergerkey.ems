		<Function ID="805" Name="JavaScript_Ref_356" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">27</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var myRS = ec_VariableHelper.GetRecordSet(&quot;RS_asOfDate&quot;);
myRS.last(); // Move the cursor to the last record in the recordset
var RS = myRS.getRow(); // Get the current row of the recordset
   var value1 = &quot;&quot;;
while (RS &gt; 0) {
    var Fields = myRS.getFields(); // Retrieve the fields of the current row
    var start = Fields;
    value1= value1 +&quot;,&quot;+ start;
    if(RS == &quot;1&quot;)
    { 
    	var dates = value1.split(&quot;,&quot;);
    	var smalldate = dates[1];
    	for(var i =2; i&lt;dates.length; i++)
    	{
    		if(dates[i]&lt; smalldate)
    		{
    			smalldate = dates[i];
    		}
    	}
    	
    	 ec_ResultHelper.ReportResultByIndex(2, smalldate)
    	 ec_ResultHelper.ReportResultByIndex(1, &quot;D8&quot;)
    	 ec_ResultHelper.ReportResultByIndex(0, &quot;356&quot;)
    }
     myRS.previous();
    RS = myRS.getRow();
  
    
}


</Property>
