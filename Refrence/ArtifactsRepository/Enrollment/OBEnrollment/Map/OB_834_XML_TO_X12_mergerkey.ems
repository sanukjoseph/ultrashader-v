    }

    // If finalResult is not set yet or current record has a later value, update
    if (!finalResult || maxValue &gt; (using3rdIndex ? finalResult[2] : finalResult[3])) {
        finalResult = maxRecord;
    }
}

// Step 4: Report final result
if (finalResult) {
    ec_ResultHelper.ReportResultByIndex(0, finalResult[0]); // codeEntry
    ec_ResultHelper.ReportResultByIndex(1, finalResult[1]); // value
}
