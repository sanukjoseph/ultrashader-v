		<Function ID="121" Name="JavaScript_MemberCommunicationNumber_Output" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">7</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">The script null checks for phone numbers and maps the corresponding code entry value and phonee number.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var Member_email = ec_VariableHelper.GetVariable(&quot;Member_email&quot;);
var Member_Phone_HP = ec_VariableHelper.GetVariable(&quot;Member_Phone_HP&quot;);
var Member_Phone_TE = ec_VariableHelper.GetVariable(&quot;Member_Phone_TE&quot;);
var Member_Phone_WP = ec_VariableHelper.GetVariable(&quot;Member_Phone_WP&quot;);
var Member_Phone_AP = ec_VariableHelper.GetVariable(&quot;Member_Phone_AP&quot;);
var Member_Phone_FX = ec_VariableHelper.GetVariable(&quot;Member_Phone_FX&quot;);
var Member_Phone_EX = ec_VariableHelper.GetVariable(&quot;Member_Phone_EX&quot;);
var Member_Phone_BN = ec_VariableHelper.GetVariable(&quot;Member_Phone_BN&quot;);
var Member_Phone_CP = ec_VariableHelper.GetVariable(&quot;Member_Phone_CP&quot;);

var flag_EM = &quot;N&quot;;
var flag_TE = &quot;N&quot;;
var flag_HP = &quot;N&quot;;
var flag_WP = &quot;N&quot;;
var flag_AP = &quot;N&quot;;
var flag_FX = &quot;N&quot;;
var flag_EX = &quot;N&quot;;
var flag_BN = &quot;N&quot;;
var flag_CP = &quot;N&quot;;

if (Member_email != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;EM&quot;);
	ec_ResultHelper.ReportResultByIndex(1, Member_email);
	flag_EM = &quot;Y&quot;;
}
else if (Member_Phone_TE != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;TE&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_TE);	
	
	flag_TE = &quot;Y&quot;;
}
else if (Member_Phone_HP != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;HP&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_HP);	
	
	flag_HP = &quot;Y&quot;;
}
else if (Member_Phone_WP != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;WP&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_WP);	
	
	flag_WP = &quot;Y&quot;;
}
else if (Member_Phone_AP != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;AP&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_AP);	
	
	flag_AP = &quot;Y&quot;;
}
else if (Member_Phone_FX != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;FX&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_FX);	
	
	flag_FX = &quot;Y&quot;;
}
else if (Member_Phone_EX != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;EX&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_EX);	
	
	flag_EX = &quot;Y&quot;;
}
else if (Member_Phone_CP != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;CP&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_CP);	
	
	flag_CP = &quot;Y&quot;;
}else if (Member_Phone_BN != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, &quot;BN&quot;);
	
	ec_ResultHelper.ReportResultByIndex(1, Member_Phone_BN);	
	
	flag_BN = &quot;Y&quot;;
}
if (Member_email !== &quot;&quot; &amp;&amp; flag_EM === &quot;N&quot;) {
    ec_ResultHelper.ReportResultByIndex(2, &quot;EM&quot;);
    ec_ResultHelper.ReportResultByIndex(3, Member_email);
    flag_EM = &quot;Y&quot;;
} else if (Member_Phone_TE !== &quot;&quot; &amp;&amp; flag_TE === &quot;N&quot;) {
    ec_ResultHelper.ReportResultByIndex(2, &quot;TE&quot;);
    ec_ResultHelper.ReportResultByIndex(3, Member_Phone_TE);
    flag_TE = &quot;Y&quot;;
} else if (Member_Phone_HP !== &quot;&quot; &amp;&amp; flag_HP === &quot;N&quot;) {
    ec_ResultHelper.ReportResultByIndex(2, &quot;HP&quot;);
    ec_ResultHelper.ReportResultByIndex(3, Member_Phone_HP);
    flag_HP = &quot;Y&quot;;
