				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">Convert the date to CCYYMMDD format.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var DOB = ec_DataHelper.GetValueByIndex(0);

if(DOB != &quot;&quot;){
	ec_ResultHelper.ReportResultByIndex(0, DOB.substr(0,4) + DOB.substr(5,2) + DOB.substr(8,2));
}</Property>
