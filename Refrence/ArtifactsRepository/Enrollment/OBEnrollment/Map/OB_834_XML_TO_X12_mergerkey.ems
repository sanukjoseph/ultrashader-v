		<Function ID="942" Name="RS_Per_2100G" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">17</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var otherResponsibilityRS = ec_VariableHelper.GetRecordSet(&quot;RS_OtherResponsibility_2100F&quot;);
var MemberIsSubscriber = ec_VariableHelper.GetVariable(&quot;MemberIsSubscriber&quot;);
myRS.last();// Move the cursor to the last record in the recordset
var RS = myRS.getRow();// Get the current row of the recordset
while (RS&gt;0)
{
	//ec_ResultHelper.println(&quot;otherResponsibilityFields[0] &quot;+otherResponsibilityFields[0]);
	var otherResponsibilityFields = otherResponsibilityRS.getFields();
	
		myRS1 = ec_VariableHelper.GetRecordSet(&quot;RS_PER_2100F&quot;);
			myRS1.last()	
			// Get the recordset  values to the array Fields
			RS1 = myRS1.getRow();
			
			while(RS1&gt;0)
			{
				Fields1 = myRS1.getFields();
				if((otherResponsibilityFields[0]==&quot;ResponsibilityTypeCode&quot;)&amp;&amp;(otherResponsibilityFields[1]!=&quot;1&quot;))
	         {

			
			
			if(Fields1[2] == &quot;TE&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(0, Fields1[0]+Fields1[1]);
			}
			else if(Fields1[2] == &quot;HP&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(1, Fields1[0]+Fields1[1]);
			}
			else if(Fields1[2] == &quot;WP&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(2, Fields1[0]+Fields1[1]);
			}
			else if(Fields1[2] == &quot;AP&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(3, Fields1[0]+Fields1[1]);
			}
			else if(Fields1[2] == &quot;FX&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(4, Fields1[0]+Fields1[1]);
			}
			else if(Fields1[2] == &quot;EX&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(5, Fields1[0]+Fields1[1]);
			}
			else if(Fields1[2] == &quot;BN&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(6, Fields1[0]+Fields1[1]);
			}
			else if(Fields1[2] == &quot;CP&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(7, Fields1[0]+Fields1[1]);
			}
			}
			  if((otherResponsibilityFields[0]==&quot;ResponsibilityTypeCode&quot;)&amp;&amp;(otherResponsibilityFields[1]!=&quot;1&quot;))
			 {
	         if(Fields1[2] == &quot;TE&quot;)
			{
			ec_ResultHelper.ReportResultByIndex(0, Fields1[0]+Fields1[1]);
			}
			}
		
		ec_ResultHelper.Send();
			myRS1.previous();// Move the cursor to the previous row in the result set
			RS1 = myRS1.getRow();
			
			
		    }
	
	
	ec_ResultHelper.Send();
	myRS.deleteRow();// Move the cursor to the previous row in the result set
	myRS.last();
	RS = myRS.getRow();// Get the current row from the result set and assign it to the RS2 variable

}	</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab33/XPos">272</Property>
				<Property Name="Tab33/YPos">-96</Property>
				<Property Name="Tab1/XPos">172</Property>
				<Property Name="Tab1/YPos">0</Property>
				<Property Name="Tab2/XPos">172</Property>
				<Property Name="Tab2/YPos">48</Property>
