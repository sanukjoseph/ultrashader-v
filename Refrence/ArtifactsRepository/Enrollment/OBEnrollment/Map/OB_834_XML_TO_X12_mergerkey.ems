		<Function ID="1046" Name="JS_INS06_01_02" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">36</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script"> var Mbi = ec_VariableHelper.GetVariable(&quot;Mbi_EffDate&quot;)
 var PartADate_ExpDate = ec_VariableHelper.GetVariable(&quot;PartADate_EffDate&quot;)
 var PartB_ExpDate = ec_VariableHelper.GetVariable(&quot;PartBDate_EffDate&quot;)
 var PartD_ExpDate = ec_VariableHelper.GetVariable(&quot;PartDDate_EffDate&quot;)
 var Esrd_ExpDate = ec_VariableHelper.GetVariable(&quot;Esrd_EffDate&quot;)
 var CodeSetName_ExpDate = ec_VariableHelper.GetVariable(&quot;CodeSetName_EffDate&quot;)
 var CodeEntry_ExpDate = ec_VariableHelper.GetVariable(&quot;CodeEntry_EffDate&quot;)





if (Mbi != &quot;&quot;) {
    // Mapping logic based on the provided combinations
    if ((PartADate_ExpDate != &quot;&quot;) &amp;&amp; (PartB_ExpDate != &quot;&quot;)&amp;&amp; (PartD_ExpDate)) {
        // A, B, D → C
        ec_ResultHelper.ReportResultByIndex(0, &quot;C&quot;);
    }
    else if ((PartADate_ExpDate != &quot;&quot;) &amp;&amp; (PartB_ExpDate != &quot;&quot;)) {
        // A and B → C
        ec_ResultHelper.ReportResultByIndex(0, &quot;C&quot;);
    }
    else if (PartADate_ExpDate != &quot;&quot; &amp;&amp; PartD_ExpDate != &quot;&quot;) {
        // A and D → A
        ec_ResultHelper.ReportResultByIndex(0, &quot;A&quot;);
    }
    else if (PartB_ExpDate != &quot;&quot; &amp;&amp; PartD_ExpDate != &quot;&quot;) {
        // B and D → B
        ec_ResultHelper.ReportResultByIndex(0, &quot;B&quot;);
    }
    else if (PartADate_ExpDate != &quot;&quot;) {
        // A alone → A
        ec_ResultHelper.ReportResultByIndex(0, &quot;A&quot;);
    }
    else if (PartB_ExpDate != &quot;&quot;) {
        // B alone → B
        ec_ResultHelper.ReportResultByIndex(0, &quot;B&quot;);
    }
    else if (PartD_ExpDate != &quot;&quot;) {
        // D alone → D
        ec_ResultHelper.ReportResultByIndex(0, &quot;D&quot;);
    }
    else {
        // No dates provided, report &quot;E&quot;
        ec_ResultHelper.ReportResultByIndex(0, &quot;E&quot;);
    }

    // Handle other flags like ESRD and Medicare eligibility
    if (Esrd_ExpDate == &quot;true&quot;) {
       ec_ResultHelper.ReportResultByIndex(1, &quot;2&quot;);
    }
    else if ((CodeEntry_ExpDate == &quot;1&quot;) &amp;&amp; (CodeSetName_ExpDate == &quot;MedicareEligibilityReason&quot;)) {
        ec_ResultHelper.ReportResultByIndex(1, &quot;0&quot;);
    }
    else if ((CodeEntry_ExpDate == &quot;3&quot;) &amp;&amp; (CodeSetName_ExpDate == &quot;MedicareEligibilityReason&quot;)) {
        ec_ResultHelper.ReportResultByIndex(1, &quot;1&quot;);
    }
}
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab36/XPos">128</Property>
				<Property Name="Tab36/YPos">0</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="5479" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5480" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="5481" FP="A" Pos="1" Name="value2"/>
				<ConnectionPoint ID="5482" FP="A" Pos="2" Name="value3"/>
				<ConnectionPoint ID="5483" FP="A" Pos="3" Name="value4"/>
