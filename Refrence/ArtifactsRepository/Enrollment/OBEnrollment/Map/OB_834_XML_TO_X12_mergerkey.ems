		<Function ID="250" Name="JavaScript - 2100F_N403" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">11</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">Concatenates zip code and zip extension code</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var ZipCode_2100F = ec_DataHelper.GetValueByIndex(0);
var ZipCodeext_2100F = ec_DataHelper.GetValueByIndex(1);

if (ZipCodeext_2100F !=&quot;&quot;) 
	 {
		ec_ResultHelper.ReportResultByIndex(0, ZipCode_2100F+ZipCodeext_2100F);
	 }

else if(ZipCode_2100F != &quot;&quot;)
    {
	    ec_ResultHelper.ReportResultByIndex(0, ZipCode_2100F);
	}</Property>
			</Properties>
