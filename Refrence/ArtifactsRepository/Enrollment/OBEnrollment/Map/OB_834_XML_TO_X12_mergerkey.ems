ec_ResultHelper.ReportResultByIndex(5,&quot;:&quot;);
ec_ResultHelper.ReportResultByIndex(6,&quot;~&quot;);
ec_ResultHelper.ReportResultByIndex(7,&quot;*&quot;);
ec_ResultHelper.ReportResultByIndex(8,&quot;^&quot;);
ec_ResultHelper.ReportResultByIndex(9, sysTime.substr(2,6));
ec_ResultHelper.ReportResultByIndex(10, sysTime.substr(9,4));

</Property>
