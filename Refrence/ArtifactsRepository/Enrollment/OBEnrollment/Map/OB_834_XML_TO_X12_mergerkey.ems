		<Function ID="779" Name="JavaScript - Control Number" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">1</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var stControlNumber = ec_VariableHelper.GetVariable(&quot;transactionControlNumber&quot;);


len=stControlNumber.length;

while(len &lt; 4)
{
	stControlNumber = &quot;0&quot; + stControlNumber;
	len++;
}

ec_ResultHelper.ReportResultByIndex(0, stControlNumber);
</Property>
