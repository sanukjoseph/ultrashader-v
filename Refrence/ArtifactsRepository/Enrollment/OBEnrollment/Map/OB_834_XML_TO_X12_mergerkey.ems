			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var sysTime = ec_VariableHelper.GetVariable(&quot;SystemTime&quot;);
var Environment = ec_VariableHelper.GetVariable(&quot;Environment&quot;);

ec_ResultHelper.ReportResultByIndex(0,&quot;00&quot;);
ec_ResultHelper.ReportResultByIndex(1,&quot;ZZ&quot;);
