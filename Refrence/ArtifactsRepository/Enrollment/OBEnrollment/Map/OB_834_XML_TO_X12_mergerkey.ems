		<Function ID="1020" Name="JS_least_Date" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">35</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var myRS = ec_VariableHelper.GetRecordSet(&quot;RS_MedicareHICN&quot;);

myRS.last();
var RS1 = myRS.getRow();

// Initialize variable to store the least (earliest) date
var leastDate = null;
var field0 = &quot;&quot;;
var field1 = &quot;&quot;;
var field2 = &quot;&quot;;
var field3 = &quot;&quot;;
var field4 = &quot;&quot;;
var field5 = &quot;&quot;;
var field6 = &quot;&quot;;
var field7 = &quot;&quot;;
var field8 = &quot;&quot;;  // Start with null to handle the first date correctly

// Loop through all records in the recordset
while (RS1 &gt; 0) {
	var Fields = myRS.getFields();
	// Only proceed if Fields[2] (the date field) is not empty
    if ((Fields[1] !== &quot;&quot;)&amp;&amp;(Fields[2]===&quot;&quot;)) {
        
            field0 = Fields[0];
            field1 = Fields[1];
            field2 = Fields[2];
            field3 = Fields[3];
            field4 = Fields[4];
            field5 = Fields[5];
            field6 = Fields[6];
            field7 = Fields[7];
            field8 = Fields[8];
        
    }

    // Move to the previous record
    myRS.previous();
    RS1 = myRS.getRow();
}
ec_ResultHelper.ReportResultByIndex(0, field0);
ec_ResultHelper.ReportResultByIndex(1, field1);
ec_ResultHelper.ReportResultByIndex(2, field2);
ec_ResultHelper.ReportResultByIndex(3, field3);
ec_ResultHelper.ReportResultByIndex(4, field4);
ec_ResultHelper.ReportResultByIndex(5, field5);
ec_ResultHelper.ReportResultByIndex(6, field6);
ec_ResultHelper.ReportResultByIndex(7, field7);
ec_ResultHelper.ReportResultByIndex(8, field8);

// After the loop, print the least (earliest) date found
if (leastDate !== null) {
    ec_ResultHelper.println(&quot;The least (earliest) date is: &quot; + leastDate.toISOString().split('T')[0]); // Print in YYYY-MM-DD format
} else {
    ec_ResultHelper.println(&quot;No valid dates found in the recordset.&quot;);
}
</Property>
