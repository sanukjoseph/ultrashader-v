		<Function ID="562" Name="JavaScript_FileEffectiveDate" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">2</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{852f0cdd-61b3-4c6c-894a-90212b6cc24e}">Current date is mapped to the DTP03 element of the file effective date segment in the target EDI guideline.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var d = new Date();
var CurrentMonth = ''+(d.getMonth()+1);
var CurrentDay = ''+d.getDate();
var CurrentYear = d.getFullYear();
if(CurrentMonth.length &lt; 2){
	var CurrentMonth = '0'+CurrentMonth;
}
if(CurrentDay.length &lt; 2){
	var CurrentDay = '0'+CurrentDay;
}
var CurrentDate = CurrentYear+CurrentMonth+CurrentDay;


ec_ResultHelper.ReportResultByIndex(0,CurrentDate);
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab2/XPos">320</Property>
