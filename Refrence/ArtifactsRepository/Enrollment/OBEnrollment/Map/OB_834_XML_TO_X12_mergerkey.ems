		<Function ID="758" Name="JavaScript_2300_Input" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">24</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">
StartDate = ec_DataHelper.GetValueByIndex(1);
EndDate = ec_DataHelper.GetValueByIndex(2);
//Retreive the recordset values
myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2300&quot;);
var resArr = new Array();
resArr [0] = &quot;030&quot;;
resArr [1] = &quot;HLT&quot;;
resArr [2] = ec_DataHelper.GetValueByIndex(0);
resArr [3] = &quot;348&quot;;
resArr [4] = &quot;D8&quot;;
resArr [5] = StartDate.substr(0,4) + StartDate.substr(5,2) + StartDate.substr(8,2);
resArr [6] = &quot;349&quot;;
resArr [7] = &quot;D8&quot;;
resArr [8] = EndDate.substr(0,4) + EndDate.substr(5,2) + EndDate.substr(8,2);
resArr [9] = &quot;CE&quot;;
resArr [10] = ec_DataHelper.GetValueByIndex(3);

myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;RS_2300&quot;, myRS, true);</Property>
			</Properties>
