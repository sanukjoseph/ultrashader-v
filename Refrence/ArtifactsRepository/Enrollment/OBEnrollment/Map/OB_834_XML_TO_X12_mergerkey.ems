				<Property Name="BGSet">7</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var address = ec_DataHelper.GetValueByName(&quot;value1&quot;);
var address2    = ec_DataHelper.GetValueByName(&quot;value2&quot;);
var cityCode              = ec_DataHelper.GetValueByName(&quot;value3&quot;);
var stateCode   = ec_DataHelper.GetValueByName(&quot;value4&quot;);
var zipCode  = ec_DataHelper.GetValueByName(&quot;value5&quot;);
var countryCode = ec_DataHelper.GetValueByName(&quot;value6&quot;);
var countyCode    = ec_DataHelper.GetValueByName(&quot;value7&quot;);

var MemberPhysicalAddressCount = ec_VariableHelper.GetVariable(&quot;MemberPhysicalAddressCount&quot;);

if(MemberPhysicalAddressCount==&quot;1&quot;)
{
	ec_ResultHelper.ReportResultByIndex(0,address)
	ec_ResultHelper.ReportResultByIndex(1,address2)
	ec_ResultHelper.ReportResultByIndex(2,cityCode)
	ec_ResultHelper.ReportResultByIndex(3,stateCode)
	ec_ResultHelper.ReportResultByIndex(4,zipCode)
	ec_ResultHelper.ReportResultByIndex(5,countryCode)
	ec_ResultHelper.ReportResultByIndex(6,countyCode)
	}</Property>
