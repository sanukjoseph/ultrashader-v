		<Function ID="1161" Name="JavaScript_2000_REF_Input_Q4" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">40</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;RS_SupplementalId_Q4&quot;);
var resArr = new Array();
//Assigns the input values to the respective indices of the array &quot;resArr&quot;

for (var i = 0; i &lt; 4; i++)
{    
	resArr[i] = ec_DataHelper.GetValueByIndex(i);
}
//Assign values of the the array &quot;resArr&quot; to the recordset array myRS 
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;RS_SupplementalId_Q4&quot;, myRS, true);</Property>
