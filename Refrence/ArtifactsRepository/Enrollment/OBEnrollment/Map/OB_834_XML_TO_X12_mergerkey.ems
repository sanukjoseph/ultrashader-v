 }
 
 else if(Mbi_ExpDate!=&quot;&quot;){
 	
 ec_ResultHelper.ReportResultByIndex(0, &quot;F6&quot;);
 ec_ResultHelper.ReportResultByIndex(1, Mbi_ExpDate);
 }
 else if(Mbi_Eff_Exp_Date!=&quot;&quot;){
 	
	ec_ResultHelper.ReportResultByIndex(0, &quot;F6&quot;); 
