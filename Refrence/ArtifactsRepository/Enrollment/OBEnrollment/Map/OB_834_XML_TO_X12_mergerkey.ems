		<Function ID="865" Name="JavaScript_2300_2310_Execute" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">24</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2300&quot;);
myRS.last();// Move the cursor to the last record in the recordset
var RS = myRS.getRow();// Get the current row of the recordset

// The code enters a while loop and continues as long as the value of RS1 is greater than 0.
while (RS&gt;0)
{
	var LX_Count = 0;
	
	
	Fields = myRS.getFields();// Retrieve the fields of the current row in the recordset using myRS.getFields()
	
	for(var i=0;i&lt;11;i++)												 			  
	{
		 ec_ResultHelper.ReportResultByIndex(i, Fields[i]);	//Report the first four values in the recordset 'Service_2320Details' to the corresponding indexes.
	}
var Plansel_StartDate =Fields[5];
var Plansel_EndDate = Fields[8];



	
myRS1 = ec_VariableHelper.GetRecordSet(&quot;RS_2310_PCP&quot;);
myRS1.last()	

// Get the recordset  values to the array Fields
RS1 = myRS1.getRow();
while(RS1&gt;0)
{

Fields1 = myRS1.getFields();


var Provider_StartDate =  Fields1[2]

if(Provider_StartDate==Plansel_StartDate)

{
	

	LX_Count++;
	ec_ResultHelper.ReportResultByIndex(11,LX_Count);
	ec_ResultHelper.ReportResultByIndex(12,&quot;P3&quot;);
	
	if(Fields1[0]!=&quot;&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(13,&quot;1&quot;);
	}
	else if(Fields1[1]!=&quot;&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(13,&quot;2&quot;);
	}
	if(Fields1[0]!=&quot;&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(14,&quot;SV&quot;);
		ec_ResultHelper.ReportResultByIndex(15,Fields1[0]);
		
	}
	else if(Fields1[1]!=&quot;&quot;)
	{
		ec_ResultHelper.ReportResultByIndex(14,&quot;SV&quot;);
		ec_ResultHelper.ReportResultByIndex(15,Fields1[1]);
		
	}
	ec_ResultHelper.ReportResultByIndex(16,&quot;72&quot;);
}

ec_ResultHelper.Send();
	myRS1.previous();// Move the cursor to the previous row in the result set
	RS1 = myRS1.getRow();
	
	
}
	ec_ResultHelper.Send();
	myRS.deleteRow();// Move the cursor to the previous row in the result set
	myRS.last();
	RS = myRS.getRow();// Get the current row from the result set and assign it to the RS2 variable

}	</Property>
			</Properties>
