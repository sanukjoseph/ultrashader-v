		<Function ID="671" Name="JavaScript_2100G_QD" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">15</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values and assign it to  myRS 
myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2100G&quot;);

// Get the recordset  values to the array Fields 
Fields = myRS.getFields();
if(Fields[5] == &quot;ResponsibilityTypeCode&quot; &amp;&amp;( Fields[6] == &quot;QD&quot;|| Fields[6] == &quot;GD&quot;))
{
//Report result to respective indexes
for(var i = 0; i &lt; 15; i++)
{
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
	ec_ResultHelper.ReportResultByIndex(15,&quot;true&quot;);
	
}
}


</Property>
			</Properties>
