		<Function ID="22" Name="Emergency_Name" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">10</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var name = ec_DataHelper.GetValueByIndex(0);
var names = new Array();
names = name.split(' ');
var lastName= names.slice(1).join(' ');

if(names != '')
{
ec_ResultHelper.ReportResultByIndex(0, names[0]);

ec_ResultHelper.ReportResultByIndex(1,lastName);
}</Property>
