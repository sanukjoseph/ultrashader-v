	{
		ec_ResultHelper.ReportResultByIndex(0, BrokerName_1000C_N102);
		ec_ResultHelper.ReportResultByIndex(1, IdentificationCode_1000C_N104);
		ec_ResultHelper.ReportResultByIndex(2, AccountNo_1100C_ACT01);
	}
}</Property>
