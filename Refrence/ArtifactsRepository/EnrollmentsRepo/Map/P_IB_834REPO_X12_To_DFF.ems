			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;Mem_SupplementalIden&quot;);

var resArr = new Array();

for (var i = 0; i &lt;2; i++)
{
 	resArr [i] = ec_DataHelper.GetValueByIndex(i);	
}

myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Mem_SupplementalIden&quot;, myRS, true);</Property>
