		<Function ID="134" Name="JS-2300IP" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">9</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;Enr_Mem_PlanSelection_2300&quot;);

var resArr = new Array();

for (var i = 0; i &lt;5; i++)
{
 	resArr [i] = ec_DataHelper.GetValueByIndex(i);	
}

myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Enr_Mem_PlanSelection_2300&quot;, myRS, true);</Property>
			</Properties>
