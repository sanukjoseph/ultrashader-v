        "paymentNumber": "${paymentNumber}",
	#{else}#end 
	#if($PaymentID)
        "paymentId": "${PaymentID}",
	#{else}#end
	#if($PaymentTransactionID)
        "paymentTransactionId": "${PaymentTransactionID}",
	#{else}#end 
	#if($RemittanceIssueDate)
        "remittanceIssueDate": "${RemittanceIssueDate}"
	#{else}#end 
#if($checkNumber)		
		"checkNumber":"${checkNumber}"	
#{else}#end 
  } #{else}#end 			
}