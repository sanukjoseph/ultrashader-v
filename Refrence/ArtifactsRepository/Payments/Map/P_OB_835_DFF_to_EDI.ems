				<ConnectionPoint ID="915" FP="X" Pos="3" Name="result4"/>
				<ConnectionPoint ID="916" FP="X" Pos="4" Name="result5"/>
				<ConnectionPoint ID="917" FP="X" Pos="5" Name="result6"/>
				<ConnectionPoint ID="918" FP="X" Pos="6" Name="result7"/>
