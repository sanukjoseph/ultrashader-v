		<Function ID="262" Name="JavaScript - Control Number" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">1</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var stControlNumber = ec_VariableHelper.GetVariable(&quot;transactionControlNumber&quot;);


len=stControlNumber.length;

while(len &lt; 4)
{
	stControlNumber = &quot;0&quot; + stControlNumber;
	len++;
}

ec_ResultHelper.ReportResultByIndex(0, stControlNumber);
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab1/XPos">208</Property>
				<Property Name="Tab1/YPos">-96</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="1096" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="1097" FP="A" Pos="0" Name="ST02"/>
				<ConnectionPoint ID="1095" FP="X" Pos="0" Name="result1"/>
			</ConnectionPoints>
		</Function>
		<Function ID="263" Name="JavaScript - Control Number" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">2</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var stControlNumber = ec_VariableHelper.GetVariable(&quot;transactionControlNumber&quot;);


len=stControlNumber.length;

while(len &lt; 4)
{
	stControlNumber = &quot;0&quot; + stControlNumber;
	len++;
}

ec_ResultHelper.ReportResultByIndex(0, stControlNumber);
</Property>
