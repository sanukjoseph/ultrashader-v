					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="901" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="902" FP="X" Pos="0" Name="result1"/>
				<ConnectionPoint ID="903" FP="X" Pos="1" Name="result2"/>
				<ConnectionPoint ID="904" FP="X" Pos="2" Name="result3"/>
				<ConnectionPoint ID="905" FP="X" Pos="3" Name="result4"/>
