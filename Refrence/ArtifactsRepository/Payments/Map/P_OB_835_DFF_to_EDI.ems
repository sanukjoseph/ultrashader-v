		<Function ID="207" Name="Convert Date/Time-CovExpDate" Template="ConvertDateTime">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">10</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="in_format">MMddyyyy</Property>
				<Property Name="out_format">CCYYMMDD</Property>
