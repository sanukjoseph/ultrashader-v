		<Function ID="1431" Name="ServiceAdjustmentInput" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">55</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Takes the input value and forms recordset.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Record Set &quot;ServiceAdjustment&quot; has information from 2430\CAS(Line Adjustment).

var GroupCode = ec_DataHelper.GetValueByIndex(0);

	//Retrieve the recordset values
	myRS = ec_VariableHelper.GetRecordSet(&quot;ServiceAdjustment_2000C&quot;);
	var resArr = new Array();
	
	//Get the input values to the array &quot;resArr&quot;
	for (var i = 0; i &lt; 19; i++) resArr [i] = ec_DataHelper.GetValueByIndex(i);
	
	//Update the recorset with elements of the array &quot;resArr&quot;
	myRS.insertRow();
	myRS.updateRow(resArr);
	ec_VariableHelper.SetRecordSet(&quot;ServiceAdjustment_2000C&quot;, myRS, true);
</Property>
			</Properties>
