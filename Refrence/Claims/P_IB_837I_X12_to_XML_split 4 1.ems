			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieves the values from change variables and assign it to the corresponding variable
var prv02 = ec_VariableHelper.GetVariable(&quot;PRV02_2000A&quot;).trim();
var prv03 = ec_VariableHelper.GetVariable(&quot;PRV03_2000A&quot;).trim();

//Checks for empty and &quot;NULL&quot; values
if(prv02 !=&quot;&quot; &amp;&amp; prv02 !=&quot;NULL&quot;)
{
	ec_ResultHelper.ReportResultByIndex(0,prv02);
	
}
//Checks for empty and &quot;NULL&quot; values
if(prv03 !=&quot;&quot; &amp;&amp; prv03 !=&quot;NULL&quot;)
{
	ec_ResultHelper.ReportResultByIndex(1,prv03);
}</Property>
