		<Function ID="1955" Name="2000B_2430" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">48</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">monetaryAmount = ec_VariableHelper.GetVariable(&quot;SVD02_2000B_2430&quot;);
monetarySumAmount = ec_VariableHelper.GetVariable(&quot;SVD02_SumAmt_2000B_2430&quot;);

if (monetarySumAmount == &quot;&quot;) {
    monetarySumAmount = 0;
}

if (monetaryAmount != &quot;&quot;) {
    var total = parseFloat(monetaryAmount) + parseFloat(monetarySumAmount);

    // Calculate decimal places in the original monetaryAmount string
    var decimalPlaces = 0;
    var decimalIndex = monetaryAmount.indexOf('.');
    if (decimalIndex !== -1) {
        decimalPlaces = monetaryAmount.length - decimalIndex - 1;
    }

    // Format the total based on decimal places count
    var formattedTotal = total.toFixed(decimalPlaces);

    ec_ResultHelper.ReportResultByIndex(0, formattedTotal);
}

</Property>
