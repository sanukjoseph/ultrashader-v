			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;ServiceAdjustment_2000C&quot;);
myRS.clear();</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab55/XPos">64</Property>
				<Property Name="Tab55/YPos">-1136</Property>
			</Properties>
			<ConnectionPoints>
