		<Function ID="1402" Name="JavaScript_CAS2320Input" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">54</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Takes the input from the segments of 2320 loop and forms a recordset.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Record Set &quot;Claim_2320CAS&quot; has information from 2320\CAS(Claim Level Adjustment).
//Retrieve the recordset values
myRS = ec_VariableHelper.GetRecordSet(&quot;Claim_2320CAS_2000C&quot;);

var resArr = new Array();

//Get the input values to the array 'resArr'
for (var i = 0; i &lt; 20; i++) resArr [i] = ec_DataHelper.GetValueByIndex(i);	

//Update the recordset with the values of the array 'resArr' 
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Claim_2320CAS_2000C&quot;, myRS, true);</Property>
			</Properties>
