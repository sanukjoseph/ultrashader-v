		<Function ID="1752" Name="JavaScript_2300_ClaimInfoInput_1" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">33</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Take the input from the 23000 loop of 2000B and creates a recordset.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values 
myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2000C_2300_CLM&quot;);

 resArr = new Array();
 
    for(i=0;i&lt;11;i++)
 {
  //Get the input values to the array &quot;resArr&quot;
 if(ec_DataHelper.GetValueByIndex(i)!=void(0) )
 	{
 	resArr[i] = ec_DataHelper.GetValueByIndex(i);
 	}
 }
 
  //Update the recprdset with values of array &quot;resArr&quot;
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;RS_2000C_2300_CLM&quot;, myRS, true);
</Property>
			</Properties>
