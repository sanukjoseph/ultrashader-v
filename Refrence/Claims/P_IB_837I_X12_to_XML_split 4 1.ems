		<Function ID="430" Name="JavaScript_2010AA_N301_And_N302" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">31</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Concatenates the address2 value with address1 separated by a comma,if address2 is present else returns the address1 value.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var address1 = ec_DataHelper.GetValueByIndex(0);
var address2 = ec_DataHelper.GetValueByIndex(1); 

 if(address2!=&quot;&quot;)
  value=address1.trim()+&quot;, &quot;+address2.trim();
