		<Function ID="718" Name="JavaScript_ExternalCauseOfInjury_Input_1" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">56</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Take the input from the 23000 loop of 2000B and creates a recordset.
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieve the recordset values
 var myRS1 = ec_VariableHelper.GetRecordSet(&quot;RS_2000B_2300_CLM2&quot;);

 resArr1 = new Array();
 
 //Get the input values to the array &quot;resArr1&quot;
 for(i=0;i&lt;12;i++)
 { if(ec_DataHelper.GetValueByIndex(i)!=void(0) )
 	{
 	resArr1[i] = ec_DataHelper.GetValueByIndex(i);
 	}
 }
 
 //Update the recprdset with values of array &quot;resArr1&quot;
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;RS_2000B_2300_CLM2&quot;, myRS1, true);
</Property>
			</Properties>
