		<Function ID="474" Name="JavaScript_2010AB_Pay-ToInfoInput" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">34</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Gets the input from 2010AB loop segments and  creates a recordset.
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">/*The recordset &quot;BillingProviderSpecialityInformation&quot; has the next inforation:
  00 - 2010AB.N301 - Address Line1
  01 - 2010AB.N301 - Address Line2
  02-2010AA.N401   - City Name
  03-2010AA.N402   - State Code
  04-2010AA.N403   - Postal Zone or ZIP Code)
  05-2010AA.N404   - Country Code*/ 
  
    
 myRS = ec_VariableHelper.GetRecordSet(&quot;PayToInfo&quot;);
 var value;
 
var resArr = new Array();

for (var i = 2; i &lt; 6; i++)
{
	 resArr[i] = ec_DataHelper.GetValueByIndex(i);
}

var address1 = ec_DataHelper.GetValueByIndex(0);
var address2 = ec_DataHelper.GetValueByIndex(1); 

 if(address2!=&quot;&quot;)
  value=address1+&quot;, &quot;+address2;
  else if(address2==&quot;&quot;)
   value=address1;
   
resArr[0]=value;



myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;PayToInfo&quot;, myRS, true);
  </Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab34/XPos">64</Property>
				<Property Name="Tab34/YPos">-416</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="5446" FP="A" Pos="0" Name="value1">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5447" FP="A" Pos="1" Name="value2">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5448" FP="A" Pos="2" Name="value3">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5449" FP="A" Pos="3" Name="value4">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5450" FP="A" Pos="4" Name="value5">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5451" FP="A" Pos="5" Name="value6">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5445" FP="X" Pos="0" Name="noOutput"/>
			</ConnectionPoints>
		</Function>
		<Function ID="475" Name="JavaScript_2010AB_Pay-ToInfoOutput_SubscriberClaim" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">34</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Triggers the recordset based on the activation and maps the value to the target guideline.
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">/*The recordset &quot;BillingProviderSpecialityInformation&quot; has the next inforation:
  00 - 2010AB.N301 - Address Line1
  01 - 2010AB.N301 - Address Line2
  02-2010AA.N401   - City Name
  03-2010AA.N402   - State Code
  04-2010AA.N403   - Postal Zone or ZIP Code)
  05-2010AA.N404   - Country Code*/ 
  
 //Gets the recordset values to the myRS array   
 myRS = ec_VariableHelper.GetRecordSet(&quot;PayToInfo&quot;);
 
//Assigns myRs array values to the array Fields
Fields = myRS.getFields();

//Assigns thee 'CountryCode' value as &quot;US&quot; if it is empty
if(Fields[5]=='')
Fields[5]='US';

//Report the results to the respective indexes
for (var i = 0; i &lt; 6; i++) 
{
if(Fields[i]!=undefined)
{
ec_ResultHelper.ReportResultByIndex(i, Fields[i].trim());
}
}</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab34/XPos">64</Property>
				<Property Name="Tab34/YPos">0</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="5458" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5459" FP="A" Pos="0" Name="noInput">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5452" FP="X" Pos="0" Name="N301"/>
				<ConnectionPoint ID="5453" FP="X" Pos="1" Name="noOutput"/>
				<ConnectionPoint ID="5454" FP="X" Pos="2" Name="N401"/>
				<ConnectionPoint ID="5455" FP="X" Pos="3" Name="N402"/>
				<ConnectionPoint ID="5456" FP="X" Pos="4" Name="N403"/>
				<ConnectionPoint ID="5457" FP="X" Pos="5" Name="N404"/>
			</ConnectionPoints>
		</Function>
