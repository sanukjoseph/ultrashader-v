		<Function ID="1481" Name="JavaScript_SubscriberName_PatientClaim" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">35</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Get the values from the change variable and assign to the respective variables
var N301 = ec_VariableHelper.GetVariable(&quot;N301_2010BA&quot;).trim();
var N401 = ec_VariableHelper.GetVariable(&quot;N401_2010BA&quot;).trim();
var N402 = ec_VariableHelper.GetVariable(&quot;N402_2010BA&quot;).trim();
var N403 = ec_VariableHelper.GetVariable(&quot;N403_2010BA&quot;).trim();
var N404 = ec_VariableHelper.GetVariable(&quot;N404_2010BA&quot;).trim();
var NM109 = ec_VariableHelper.GetVariable(&quot;NM109_2010BA&quot;).trim();

var NM103 = ec_VariableHelper.GetVariable(&quot;NM103_2010BA&quot;).trim();
var NM104 = ec_VariableHelper.GetVariable(&quot;NM104_2010BA&quot;).trim();
var NM105 = ec_VariableHelper.GetVariable(&quot;NM105_2010BA&quot;).trim();
var NM107 = ec_VariableHelper.GetVariable(&quot;NM107_2010BA&quot;).trim();

//Report the result if the value is not empty
if(N301 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(0,N301);
	
}
//Report the result if the value is not empty
if(N401 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(1,N401);
}
//Report the result if the value is not empty
if(N402 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(2,N402);
	
}
//Report the result if the value is not empty
if(N403 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(3,N403);
}
//Report the result if the value is not empty
if(N404 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(4,N404);
	
}
else
ec_ResultHelper.ReportResultByIndex(4,&quot;US&quot;);
//Report the result if the value is not empty
if(NM109 !=&quot;&quot;)
{  
 
    NM109 = NM109.replace(/[^\w\-]/g, '');;//Replace special characters expect hyphen
  	ec_ResultHelper.ReportResultByIndex(5,NM109);
}

if(NM103 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(6,NM103);
}
//Report the result if the value is not empty
if(NM104 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(7,NM104);
}
//Report the result if the value is not empty
if(NM105 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(8,NM105);
}
//Report the result if the value is not empty
if(NM107 !=&quot;&quot;)
{
	ec_ResultHelper.ReportResultByIndex(9,NM107);
}

var subName ;//declare the variable to store the subscriber full name

//Check whether corresponding names are present, concatenates add spaces only if required

/*if (NM104) {
  subName = NM104;
}

if (NM105) {
  if (subName) {
    subName += &quot;,&quot; + NM105;
  } else {
    subName = NM105;
  }
}

if (NM103) {
  if (subName) {
    subName += &quot;,&quot; + NM103;
  } else {
    subName = NM103;
  }
}

if (NM107) {
  if (subName) {
    subName += &quot;,&quot; + NM107;
  } else {
    subName = NM107;
  }
}*/

subName = NM103+&quot;,&quot;+NM105+&quot;,&quot;+NM104+&quot;,&quot;+NM107; 
//Trim and report the result
if(subName!=undefined)
ec_ResultHelper.ReportResultByIndex(10,subName.trim());
ec_ResultHelper.Send();</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab35/XPos">64</Property>
				<Property Name="Tab35/YPos">-496</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="12627" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="12628" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="14624" FP="X" Pos="0" Name="N301"/>
				<ConnectionPoint ID="14628" FP="X" Pos="1" Name="N401"/>
				<ConnectionPoint ID="14629" FP="X" Pos="2" Name="N402"/>
				<ConnectionPoint ID="14630" FP="X" Pos="3" Name="N403"/>
				<ConnectionPoint ID="14631" FP="X" Pos="4" Name="N404"/>
				<ConnectionPoint ID="12619" FP="X" Pos="5" Name="NM109"/>
				<ConnectionPoint ID="12622" FP="X" Pos="6" Name="NM103"/>
				<ConnectionPoint ID="12623" FP="X" Pos="7" Name="NM104"/>
				<ConnectionPoint ID="12624" FP="X" Pos="8" Name="NM105"/>
				<ConnectionPoint ID="12625" FP="X" Pos="9" Name="NM107"/>
				<ConnectionPoint ID="12626" FP="X" Pos="10" Name="FullName"/>
			</ConnectionPoints>
