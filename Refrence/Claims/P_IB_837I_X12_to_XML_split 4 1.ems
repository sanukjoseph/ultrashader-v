			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values 
myRS = ec_VariableHelper.GetRecordSet(&quot;ClaimInfo_2000C_3&quot;);

//Get the recordset values to the array &quot;Fields&quot;
Fields = myRS.getFields();

//Report result from array &quot;Fields&quot; to indexes
for(var i = 0; i &lt; 8; i++)
{
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
}</Property>
