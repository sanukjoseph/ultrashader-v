		<Function ID="1765" Name="JavaScript-2300_ClaimInfoOutput_2" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">33</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;ClaimInfo_2000C_2&quot;);
myRS.last();
do {
	
   var RS = myRS.getRow();
  

    if (RS &gt; 0) 
	{
	
			Fields = myRS.getFields();	
		    ec_ResultHelper.Send();
			
			for(i=0;i&lt;7;i++)
            {
				if(Fields[i]!=&quot;&quot; &amp;&amp; Fields[i] != &quot;undefined&quot; &amp;&amp; Fields[i]!= null)
 	         // Report the value of the field at index i
               ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
 
            }
		
	}
		
    }while (myRS.previous());</Property>
			</Properties>
