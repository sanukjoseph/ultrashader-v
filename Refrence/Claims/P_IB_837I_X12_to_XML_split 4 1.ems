		<Function ID="417" Name="JavaScript_2010AA_BillingProviderInfoInput" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">31</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Get the input from 2010AA loop and creates a recordset. </Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">/*Record Set &quot;BillingProvider&quot; has next information:
00-2010AA.NM103 (Last Name) 
01-2010AA.NM109 (Billing Provider Identifier) 
02-2010AA.N301  (Address Line#1) 
03-2010AA.N401  (City Name) 
04-2010AA.N402  (State Code) 
05-2010AA.N403  (Postal Zone or ZIP Code) 
06-2010AA.N404  (Country Code) 
07-2010AA.REF02 (Reference Identification)
08-2010AA.N403(byte 1-5) (zip Code)
09-2010AA.N403(byte 6-9) (zip Suffix Code)
10-2010AA.PER04/06/08 (Telephone Number) 
11-2010AA.PER04/06/08 (Fax Number) */

//Assigns recordset values into array &quot;myRS&quot;
myRS = ec_VariableHelper.GetRecordSet(&quot;BillingProvider&quot;);

var resArr = new Array();




//Assigns the input values to the respective indices of the array &quot;resArr&quot;

for (var i = 0; i &lt; 16; i++)
{    
	
			 resArr[i] = ec_DataHelper.GetValueByIndex(i);
	
}



//Assign values of the the array &quot;resArr&quot; to the recordset array myRS 
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;BillingProvider&quot;, myRS, true);</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab31/XPos">64</Property>
				<Property Name="Tab31/YPos">0</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="3352" FP="A" Pos="0" Name="value1">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="3353" FP="A" Pos="1" Name="value2">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="3357" FP="A" Pos="2" Name="value6">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="3358" FP="A" Pos="3" Name="value7">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="3359" FP="A" Pos="4" Name="value8">
					<Properties Category="Runtime">
