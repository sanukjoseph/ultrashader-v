		<Function ID="691" Name="JavaScript_2300_DateFormatConversion" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">32</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Converts the date from yyyymmdd to yyyy-mm-dd.
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Change the date format to yyyy-mm-dd
var date = ec_DataHelper.GetValueByIndex(0);

 var date1 = date.substring(0,4);
 var date2 = date.substring(4,6);
 var date3 = date.substring(6,8);
 
 ec_ResultHelper.ReportResultByIndex(0,date1+&quot;-&quot;+date2+&quot;-&quot;+date3); 
 </Property>
			</Properties>
