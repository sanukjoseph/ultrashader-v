		<Function ID="680" Name="JavaScript_2300_ClaimInfoInput_1" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">32</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Take the input from the 23000 loop of 2000B and creates a recordset.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">
//Retrieve the recordset values and assigns it to the array 'myRS'
myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2000B_2300_CLM&quot;);

 resArr = new Array();
 
  for(i=0;i&lt;11;i++)
 {
 //Assigns input valyes to resArr array
 if(ec_DataHelper.GetValueByIndex(i)!=void(0) )
 	{
 	resArr[i] = ec_DataHelper.GetValueByIndex(i);
 	}
 }
 //Update the recorset with the values of the array 'resArr'
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;RS_2000B_2300_CLM&quot;, myRS, true);
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab32/XPos">64</Property>
