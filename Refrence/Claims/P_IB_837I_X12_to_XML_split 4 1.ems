		<Function ID="1073" Name="JavaScript_2410_DrugIdentificationOutput" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">46</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Trigger the recordset based on the activation and maps the output to the target guideline.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the values of recordset &quot;RS_2000B_2410&quot;
myRS = ec_VariableHelper.GetRecordSet(&quot;RS_2000B_2410&quot;);

// Get the recordset values to the array 'Fields'
Fields = myRS.getFields();
if(Fields[1]!=&quot;&quot;)
{
var ndcCode = Fields[1];



 var ndcCode1 = ndcCode.substring(0,5);
 var ndcCode2 = ndcCode.substring(5,9);
 var ndcCode3 = ndcCode.substring(9);
 
 
 Fields[1] = ndcCode1+&quot;-&quot;+ndcCode2+&quot;-&quot;+ndcCode3; 
 

}
for(var i = 0; i &lt; 4; i++)
{
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);//Report the elements of the array &quot;Fields&quot; to corresponding indexes
}</Property>
			</Properties>
