		<Function ID="1928" Name="JavaScript_DRG_Output" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">33</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values
myRS1 = ec_VariableHelper.GetRecordSet(&quot;RS_2000C_2300_CLM14&quot;);
 
//Get the rcordset values to the array Fields1
Fields1 = myRS1.getFields();
 
//Report the Fields1 array values to indexes
for(var i = 0; i &lt; 1; i++)
{  
		ec_ResultHelper.ReportResultByIndex(i,Fields1[i]);
}</Property>
			</Properties>
