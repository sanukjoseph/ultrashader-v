		<Function ID="1676" Name="JavaScript_OccurrenceSpanInformation_Output_2" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">65</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Triggers the recordset based on activation and maps the result to target guideline.
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values 
myRS1 = ec_VariableHelper.GetRecordSet(&quot;RS_2000C_OccurrenceSpanInfo&quot;);

//Get the recordset values to the array &quot;Fields1&quot;
Fields1 = myRS1.getFields();

//Report result from array &quot;Fields1&quot; to indexes
for(var i = 0; i &lt; 12; i++)
{    

	ec_ResultHelper.ReportResultByIndex(i,Fields1[i]);
	
	
}</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab65/XPos">64</Property>
				<Property Name="Tab65/YPos">-576</Property>
				<Property Name="Tab1/XPos">-271</Property>
				<Property Name="Tab1/YPos">-440</Property>
				<Property Name="Tab30/XPos">-298</Property>
				<Property Name="Tab30/YPos">-80</Property>
				<Property Name="Tab31/XPos">-254</Property>
				<Property Name="Tab31/YPos">-80</Property>
				<Property Name="Tab34/XPos">-273</Property>
				<Property Name="Tab34/YPos">-80</Property>
				<Property Name="Tab35/XPos">-254</Property>
				<Property Name="Tab35/YPos">-80</Property>
				<Property Name="Tab36/XPos">-285</Property>
