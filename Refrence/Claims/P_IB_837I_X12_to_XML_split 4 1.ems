		<Function ID="1851" Name="JavaScript- nonCoveredTotals" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">53</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">
var nonCovAmt = ec_DataHelper.GetValueByIndex(0);
var nonCovVariable = ec_VariableHelper.GetVariable(&quot;NonCoveredTotals_2000B&quot;);

if(nonCovVariable == &quot;&quot;)
{
	nonCovVariable = 0;
}
if(nonCovAmt != &quot;&quot;)
{
	nonCovVariable = +nonCovAmt + +nonCovVariable;
	ec_ResultHelper.ReportResultByIndex(0, nonCovVariable);
}
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab53/XPos">64</Property>
				<Property Name="Tab53/YPos">-480</Property>
			</Properties>
