		<Function ID="420" Name="Substring_2010AA_ZipCode" Template="Substring">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">31</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Take the first 5 bytes of the input.</Property>
