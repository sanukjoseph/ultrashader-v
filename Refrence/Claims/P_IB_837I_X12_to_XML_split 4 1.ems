		<Function ID="1379" Name="ServiceLineCAScodes_Output" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">48</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Trigger the recordset based on activation.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values
myRS3 = ec_VariableHelper.GetRecordSet(&quot;LineCAS_CO_PR&quot;);//CO PR
lineNum = ec_VariableHelper.GetVariable(&quot;LineNumber&quot;);
myRS3.last(); 
var RS3 = myRS3.getRow();
while (RS3&gt;0)
{
	//Assign the recordset values to the array &quot;Fields3&quot;
	Fields3 = myRS3.getFields();
	if(Fields3[19] == lineNum)
	{
		for (var i=0; i&lt;6; i++)
		{
				if((Fields3[i*3+1] != &quot;&quot;) &amp;&amp; (Fields3[i*3+1] != &quot;undefined&quot;))
						{
							var CASamount = parseFloat(Fields3[i*3+2]);
							ec_ResultHelper.ReportResultByIndex(0, Fields3[i*3+1]);//Cascode
							ec_ResultHelper.ReportResultByIndex(1, Fields3[0]);//Groupcode
							ec_ResultHelper.ReportResultByIndex(2, CASamount.toFixed(2));//Amount
							ec_ResultHelper.ReportResultByIndex(3, Fields3[i*3+3]);//Quantity
							ec_ResultHelper.Send();
						}
		}
	}
	myRS3.previous();
	RS3 = myRS3.getRow();
}</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab48/XPos">64</Property>
				<Property Name="Tab48/YPos">-2016</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="12050" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="12051" FP="A" Pos="0" Name="value0"/>
				<ConnectionPoint ID="12046" FP="X" Pos="0" Name="2430_CAS02,05,08,11,14,17"/>
				<ConnectionPoint ID="12047" FP="X" Pos="1" Name="2430_CAS01"/>
				<ConnectionPoint ID="12048" FP="X" Pos="2" Name="2430_CAS03,06,09,12,15,18"/>
				<ConnectionPoint ID="12049" FP="X" Pos="3" Name="2430_CAS04,07,10,13,16,19"/>
			</ConnectionPoints>
		</Function>
