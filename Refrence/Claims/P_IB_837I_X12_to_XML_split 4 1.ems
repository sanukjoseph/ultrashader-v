			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{a2e970b9-d1eb-4551-9d3b-55c439527346}">Takes the input value and forms a recordset.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieve the recordset values to the array myRS1
 var myRS1 = ec_VariableHelper.GetRecordSet(&quot;RS_2000B_2300_CLM9&quot;);

 resArr1 = new Array();

//Assign the input values to the ressArr1 array if it is not empty or undefined 
 for(i=0;i&lt;2;i++)
 { if(ec_DataHelper.GetValueByIndex(i)!=void(0) )
 	{
 	resArr1[i] = ec_DataHelper.GetValueByIndex(i);
 	}
 }
 //Update the recordset with the values of array resArr1
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;RS_2000B_2300_CLM9&quot;, myRS1, true);
</Property>
