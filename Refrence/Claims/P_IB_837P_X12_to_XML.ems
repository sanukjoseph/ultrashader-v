		<Function ID="222" Name="JavaScript-Record Set-Referring_Provider_2310A" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">12</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Record Set for Reffering Provider 2310A
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Referring_Provider_2310A_2000B&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
var resArr = new Array();

for (var i = 0; i &lt; 8; i++)
{
  resArr [i] = ec_DataHelper.GetValueByIndex(i);	
}
//Updating the newly inserted row with the values from the array
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Referring_Provider_2310A_2000B&quot;, myRS, true);</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab12/XPos">64</Property>
				<Property Name="Tab12/YPos">-688</Property>
			</Properties>
