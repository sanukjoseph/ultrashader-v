		<Function ID="1613" Name="JavaScript_RecordSet-1" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">8</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Reseting the recorset ie,removing junk values
myRS20 = ec_VariableHelper.GetRecordSet(&quot;Subscriber_Name_2010BA_2000B_2000C&quot;);
myRS20.clear();
myRS20.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Subscriber_Name_2010BA_2000B_2000C&quot;, myRS20, true);

</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab8/XPos">64</Property>
				<Property Name="Tab8/YPos">-672</Property>
			</Properties>
