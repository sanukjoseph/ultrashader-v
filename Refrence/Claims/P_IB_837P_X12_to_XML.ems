		<Function ID="585" Name="JavaScript-Trigger Subscriber_Info-2000B_2000C" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">9</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Triggering Record Set Subscriber_Info used to map in Patient Claim</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">
myRS = ec_VariableHelper.GetRecordSet(&quot;Subscriber_Info&quot;);
myRS.last();
Fields = myRS.getFields();

for(var i = 0; i &lt; 5; i++)
{
	if(Fields[i] != &quot;&quot; || Fields[i] != undefined)
	{
	// Report the value of the field at index i
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
	}
}
myRS.previous();</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab7/XPos">176</Property>
				<Property Name="Tab7/YPos">-176</Property>
				<Property Name="Tab9/XPos">176</Property>
				<Property Name="Tab9/YPos">-112</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="5064" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="5065" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="5060" FP="X" Pos="0" Name="SBR02"/>
				<ConnectionPoint ID="5061" FP="X" Pos="1" Name="SBR03"/>
				<ConnectionPoint ID="5062" FP="X" Pos="2" Name="SBR04"/>
				<ConnectionPoint ID="5063" FP="X" Pos="3" Name="SBR05"/>
				<ConnectionPoint ID="12721" FP="X" Pos="4" Name="SBR09"/>
			</ConnectionPoints>
		</Function>
		<Function ID="587" Name="JavaScript-Trigger -SUBInformation-2010BA_2000B" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">8</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Triggering Record Set Subscriber_Name_2010BA for mapping Subscriber Information for Subscriber claim.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS1 = ec_VariableHelper.GetRecordSet(&quot;Subscriber_Name_2010BA_2000B_2000C&quot;);
Fields1 = myRS1.getFields();//getting the recorset values


if(Fields1[0] != &quot; &quot;)
{
ec_ResultHelper.ReportResultByIndex(0,Fields1[0].trim());//Last Name
}
 
if(Fields1[1] != &quot; &quot;)
{
ec_ResultHelper.ReportResultByIndex(1,Fields1[1].trim());// First Name
}
if(Fields1[2] != &quot; &quot;)
{
ec_ResultHelper.ReportResultByIndex(2,Fields1[2].trim());//Middle Name
}
if(Fields1[3] != &quot; &quot;)
{
ec_ResultHelper.ReportResultByIndex(3,Fields1[3].trim());//Name Suffix
}
ec_ResultHelper.ReportResultByIndex(4,Fields1[4].trim());// id
ec_ResultHelper.ReportResultByIndex(5,Fields1[5].trim());//add
ec_ResultHelper.ReportResultByIndex(6,Fields1[6].trim());//city
ec_ResultHelper.ReportResultByIndex(7,Fields1[7].trim());//state
ec_ResultHelper.ReportResultByIndex(8,Fields1[8].trim());//postal


//ec_ResultHelper.Send();

if(Fields1[9]!= &quot;&quot;)//Country Code
{
	ec_ResultHelper.ReportResultByIndex(9,Fields1[9].trim());
	ec_ResultHelper.Send();
	
}
else
{
	ec_ResultHelper.ReportResultByIndex(9,&quot;US&quot;);
	ec_ResultHelper.Send();
	
}


ec_ResultHelper.ReportResultByIndex(10,Fields1[10].trim());//DOB
ec_ResultHelper.ReportResultByIndex(11,Fields1[11].trim());//GenderCode
ec_ResultHelper.ReportResultByIndex(12,Fields1[12].trim()); //Communication num1
ec_ResultHelper.ReportResultByIndex(13,Fields1[13].trim()); //sub phn exten num(Communication num2)



ec_ResultHelper.Send();
	
</Property>
			</Properties>
