		<Function ID="223" Name="JavaScript-Trigger-Referring_Provider_2310A" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">12</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Triggering Record Set for Reffering Provider 2310A</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the values from recordset and storing it in change variables outside the javascript function
myRS = ec_VariableHelper.GetRecordSet(&quot;Referring_Provider_2310A_2000B&quot;);


Fields = myRS.getFields();

for(var i = 0; i &lt; 7; i++)
{
	if(Fields[7]== &quot;DN&quot;)
	{
	ec_ResultHelper.ReportResultByIndex(i,Fields[i].trim());
	}
}


</Property>
