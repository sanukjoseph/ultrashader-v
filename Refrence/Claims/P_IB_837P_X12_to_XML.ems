		<Function ID="56" Name="JavaScript-TriggerRecordsets-2010AA" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">6</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Mapping Done for supplier Information only  by triggering the Record sets Using Javascript .
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS1 = ec_VariableHelper.GetRecordSet(&quot;BillingProvider_2000A&quot;);
myRS2 = ec_VariableHelper.GetRecordSet(&quot;Rendering_Prov_2310B_2000B&quot;);
myRS3 = ec_VariableHelper.GetRecordSet(&quot;Rendering_Prov_2420A_2000B&quot;);


var nm103 = ec_VariableHelper.GetVariable(&quot;NM103_NameLast_2420A_2000B&quot;);
var nm104 = ec_VariableHelper.GetVariable(&quot;NM104_NameFirst_2420A_2000B&quot;);
var nm105 = ec_VariableHelper.GetVariable(&quot;NM105_NameMiddle_2420A_2000B&quot;);
var nm107 = ec_VariableHelper.GetVariable(&quot;NM107_NameSuffix_2420A_2000B&quot;);
var nm109 = ec_VariableHelper.GetVariable(&quot;NM109_IdentifcationCode_2420A_2000B&quot;);
var prv03 = ec_VariableHelper.GetVariable(&quot;PRV03_REFIdentification_2420A_2000B&quot;);
var ref01 = ec_VariableHelper.GetVariable(&quot;REF01_RefQualifier_2420A_2000B&quot;);
var ref02 = ec_VariableHelper.GetVariable(&quot;REF02_REFID_2420A_2000B&quot;);

Fields3 = myRS3.getFields();
Fields2 = myRS2.getFields();
Fields1 = myRS1.getFields();

var nm1032310B = ec_VariableHelper.GetVariable(&quot;NM103_NameLast_2310B_2000B&quot;);
var nm1042310B = ec_VariableHelper.GetVariable(&quot;NM104_NameFirst_2310B_2000B&quot;);
var nm1052310B = ec_VariableHelper.GetVariable(&quot;NM105_NameMiddle_2310B_2000B&quot;);
var nm1072310B = ec_VariableHelper.GetVariable(&quot;NM107_NameSuffix_2310B_2000B&quot;);
var nm1092310B = ec_VariableHelper.GetVariable(&quot;NM109_IdentiCode_2310B_2000B&quot;);
var prv032310B = ec_VariableHelper.GetVariable(&quot;PRV03_REFID_2310B_2000B&quot;);
var ref012310B = ec_VariableHelper.GetVariable(&quot;REF01_REFID_2310B_2000B&quot;);
var ref022320B = ec_VariableHelper.GetVariable(&quot;REF02_REFID_2310_2000B&quot;);



if(Fields1[1]== 1)        //first name
{
	ec_ResultHelper.ReportResultByIndex(0,Fields1[3].trim());
	ec_ResultHelper.Send();
}



if(Fields1[1]== 1)//middle name
{
	ec_ResultHelper.ReportResultByIndex(1,Fields1[4].trim());
	ec_ResultHelper.Send();
}




	
if(Fields1[1]== 1)//name suffi
{
	ec_ResultHelper.ReportResultByIndex(2,Fields1[5].trim());
	ec_ResultHelper.Send();
}




	if(Fields1[7] != &quot;&quot; )
	{
	ec_ResultHelper.ReportResultByIndex(3,Fields1[7].trim());//first instance street add
	ec_ResultHelper.Send();
	}
	


    if (Fields1[8] != &quot;&quot;)
	{
    ec_ResultHelper.ReportResultByIndex(8,Fields1[8].trim());// second instance street address if N302 is present
	ec_ResultHelper.Send();
	}
	


if(Fields1[12] == &quot;&quot;) //Country Code
{
    ec_ResultHelper.ReportResultByIndex(4,&quot;US&quot;);
}
else
{
    ec_ResultHelper.ReportResultByIndex(4,Fields1[12].trim());
}




if(Fields1[13] == &quot;EI&quot;)// REF02-TaxIdentification Number
{
var Referenceid = Fields1[14];
var Appendchar= &quot;-&quot;
var pos=2
// Concatenating substrings with an append character &quot;-&quot;
Referenceid = Referenceid.substring(0,pos)+ Appendchar + Referenceid.substring(pos,Referenceid.length);

ec_ResultHelper.ReportResultByIndex(5,Referenceid.trim());
ec_ResultHelper.Send();
}
else if(Fields1[13] == &quot;SY&quot;)
{
var Referenceid = Fields1[14];
var Appendchar= &quot;-&quot;
//var pos=2

Referenceid = Referenceid.substring(0,3)+ Appendchar + Referenceid.substring(3,5) + Appendchar + Referenceid.substring(5,Referenceid.length);

ec_ResultHelper.ReportResultByIndex(5,Referenceid);
ec_ResultHelper.Send();
}

if(Fields1[13] == &quot;SY&quot;) //otherid
{
ec_ResultHelper.ReportResultByIndex(6,Fields1[14]);
ec_ResultHelper.Send();
}
else if(Fields1[15] == &quot;1G&quot; || Fields1[15] == &quot;0B&quot;)
{
ec_ResultHelper.ReportResultByIndex(6,Fields1[16]);
ec_ResultHelper.Send();
}

ec_ResultHelper.ReportResultByIndex(7,Fields1[2].trim());//supplierName



</Property>
