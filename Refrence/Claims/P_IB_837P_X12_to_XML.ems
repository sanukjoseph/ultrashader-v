		<Function ID="931" Name="JavaScript-Supervising_Provider_2420D" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">41</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Supervising_Provider_2420D_2000C&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
var resArr = new Array();

for (var i = 0; i &lt; 6; i++)
{
  resArr [i] = ec_DataHelper.GetValueByIndex(i);	
}
//Updating the newly inserted row with the values from the array
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Supervising_Provider_2420D_2000C&quot;, myRS, true);</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab41/XPos">64</Property>
				<Property Name="Tab41/YPos">0</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="7209" FP="A" Pos="0" Name="value1">
