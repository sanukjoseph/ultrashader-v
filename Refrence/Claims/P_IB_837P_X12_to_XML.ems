			<Properties Category="BusinessGroups">
				<Property Name="BGSet">17</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Triggering Record set Service_Line_Loop_2400.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;ServiceLineLoop_Input1_2000B&quot;);

Fields = myRS.getFields();

for(var i = 0; i &lt;12; i++)
{
   // Report the value of the field at index i
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
}</Property>
