		<Function ID="1133" Name="JavaScript-ServiceAdjustment" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">24</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Mapping done for Service Line Adjustment</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS = ec_VariableHelper.GetRecordSet(&quot;ServiceAdjustment_2000B&quot;);//CO PR
myRS.last(); // select last row
var RS = myRS.getRow();// Get the current row number
var arrayResult = [0,0,0,0,0,0,0,0,0];// // Array to store result values: [0]-PR:1, [1]-PR:2, [2]-PR:225/237/B4, [3]-PR:3, [4]-CO:225/237/B4, [5]-CO:45,  [6,7]-Others
allowedAmt_Line = 0;
var netPaidAmt = ec_VariableHelper.GetVariable(&quot;SVD02_2430_MonetaryAmt_2000B&quot;);
var sumAmmount = ec_VariableHelper.GetVariable(&quot;SVD02_2430_MonetarySumAmt_2000B&quot;);

//var billedAmount = ec_VariableHelper.GetVariable(&quot;SV203_billedAmount_2400&quot;);
var Loop2430_Present = ec_VariableHelper.GetVariable(&quot;Flag_2430Present_2000B&quot;);

if(sumAmmount!= &quot;&quot;)
{
	
	ec_ResultHelper.ReportResultByIndex(10, sumAmmount);//netPaidAmount	
	
}
while (RS&gt;0)
{
	Fields = myRS.getFields();// Get the fields in the current row of the recordset
	
	
	for (var i=0; i&lt;6; i++)
		{
			if (Fields[0] == &quot;PR&quot;)// If the field is PR
			{
				switch (Fields[i*3+1])
				{
					case &quot;1&quot;:
						arrayResult[0] = +arrayResult[0] + +Fields[i*3+2];// Add value to arrayResult[0]
						break;
					case &quot;2&quot;:
						arrayResult[1] = +arrayResult[1] + +Fields[i*3+2];// Add value to arrayResult[1]
						break;
					case &quot;225&quot;:
						arrayResult[2] = +arrayResult[2] + +Fields[i*3+2];// Add value to arrayResult[2]
						break;
					case &quot;237&quot;:
						arrayResult[2] = +arrayResult[2] + +Fields[i*3+2];// Add value to arrayResult[2]
						break;
					case &quot;B4&quot;:
						arrayResult[2] = +arrayResult[2] + +Fields[i*3+2];// Add value to arrayResult[2]
						break;
					case &quot;3&quot;:
						arrayResult[3] = +arrayResult[3] + +Fields[i*3+2];// Add value to arrayResult[3]
						break;
					default:
							arrayResult[7] = +arrayResult[7] + +Fields[i*3+2];// Add value to arrayResult[6]
							
					
				}
				allowedAmt_Line = +allowedAmt_Line + +Fields[i*3+2];// Update the allowed amount
				
				
			}
			
			else
			{
				if (Fields[0] == &quot;CO&quot;)// If the field is CO 
				{
					switch (Fields[i*3+1])
					{
						case &quot;225&quot;:
							arrayResult[4] = +arrayResult[4] + +Fields[i*3+2];//Add value to arrayResult[4]
							break;
						case &quot;237&quot;:
							arrayResult[4] = +arrayResult[4] + +Fields[i*3+2];// Add value to arrayResult[4]
							break;
						case &quot;B4&quot;:
							arrayResult[4] = +arrayResult[4] + +Fields[i*3+2];// Add value to arrayResult[4]
							break;
						case &quot;45&quot;:
							arrayResult[5] = +arrayResult[5] + +Fields[i*3+2];// Add value to arrayResult[5]
							break;
						case &quot;105&quot;:
							arrayResult[6] = +arrayResult[6] + +Fields[i*3+2];// Add value to arrayResult[5]
							break;
					
						default:
							arrayResult[8] = +arrayResult[8] + +Fields[i*3+2];// Add value to arrayResult[7]
							
					}
				}
			}
		
		}
		
		
		ec_ResultHelper.Send();
		myRS.previous();
		RS = myRS.getRow();
}

arrayResult[7] = +arrayResult[7] + +arrayResult[8];

for (var i=0; i&lt;8; i++)
{
	if (arrayResult[i] != 0 &amp;&amp; arrayResult[i] != &quot;&quot; &amp;&amp; arrayResult[i] != undefined ) 
	{
		ec_ResultHelper.ReportResultByIndex(i, parseFloat(arrayResult[i]).toFixed(2));
	}
}
if(Loop2430_Present == &quot;1&quot;)
{     

if(allowedAmt_Line!=0 &amp;&amp; allowedAmt_Line!= &quot;&quot; &amp;&amp; allowedAmt_Line!= undefined)
{
 ec_ResultHelper.ReportResultByIndex(8, parseFloat(allowedAmt_Line).toFixed(2));//Allowed amount
}
 

}


//ec_ResultHelper.ReportResultByIndex(8, billedAmount)//billedAmount
</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab24/XPos">64</Property>
				<Property Name="Tab24/YPos">-256</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="8451" FP="_AP" Name="activation">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="8452" FP="A" Pos="0" Name="value1"/>
