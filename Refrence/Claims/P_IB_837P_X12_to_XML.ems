		<Function ID="1736" Name="JavaScript-PWK06-AttachmentsetRefID" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">47</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">first occured  pwk06 value</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var pwk06 = ec_DataHelper.GetValueByIndex(0);

var pwk06new = ec_VariableHelper.GetVariable(&quot;PWK06_2000B&quot;);

 if(pwk06new == &quot;&quot;)
 {
   pwk06 == pwk06new;
 	
 	ec_ResultHelper.ReportResultByIndex(0,pwk06);
 	
 }</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab47/XPos">128</Property>
				<Property Name="Tab47/YPos">-1056</Property>
			</Properties>
			<ConnectionPoints>
				<ConnectionPoint ID="12583" FP="A" Pos="0" Name="value1">
					<Properties Category="Runtime">
						<Property Name="ResetValue">true</Property>
