		<Function ID="768" Name="JavaScript-Trigger-2420A RenderingProvider" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">27</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Triggering Record set for Rendering Provider 2420A_2000C loop</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Rendering_Prov_2420A_2000C&quot;);

Fields = myRS.getFields();

for(var i = 0; i &lt; 8; i++)
{
	// Report the value of the field at index i
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
}</Property>
			</Properties>
