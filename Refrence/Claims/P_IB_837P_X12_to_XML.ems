						<Property Name="ResetValue">true</Property>
					</Properties>
				</ConnectionPoint>
				<ConnectionPoint ID="12119" FP="A" Pos="0" Name="value1"/>
				<ConnectionPoint ID="12117" FP="X" Pos="0" Name="result1"/>
			</ConnectionPoints>
		</Function>
		<Function ID="1615" Name="JavaScript-PhoneDetails" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">8</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var Per04= ec_DataHelper.GetValueByIndex(0);
var length = Per04.length;
 if(length &gt;10)
 {
 var PhoneAreaCode = Per04.substring(0, 3);
 var Countrycode = Per04.substring(0, 1);
 var phnnum = Per04.substr(-7);

 ec_ResultHelper.ReportResultByIndex(0,Countrycode);
 ec_ResultHelper.ReportResultByIndex(1,PhoneAreaCode);
 ec_ResultHelper.ReportResultByIndex(2,phnnum);
 }
 else if(length = 10)
 { 	
 var PhoneAreaCode = Per04.substring(0, 3);
 var phnnum = Per04.substr(-7);
 //ec_ResultHelper.ReportResultByIndex(0,Countrycode);
 ec_ResultHelper.ReportResultByIndex(1,PhoneAreaCode);
 ec_ResultHelper.ReportResultByIndex(2,phnnum);
 }</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab8/XPos">368</Property>
				<Property Name="Tab8/YPos">-240</Property>
				<Property Name="Tab1/XPos">234</Property>
				<Property Name="Tab1/YPos">-224</Property>
				<Property Name="Tab33/XPos">192</Property>
				<Property Name="Tab33/YPos">-158</Property>
				<Property Name="Tab6/XPos">236</Property>
				<Property Name="Tab6/YPos">-175</Property>
				<Property Name="Tab4/XPos">236</Property>
				<Property Name="Tab4/YPos">-158</Property>
