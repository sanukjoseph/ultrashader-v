		<Function ID="591" Name="JavaScript-Submitted_SubscriberID" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">8</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Remove all special characters including space and map only the alphanumeric characters.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var subID= ec_DataHelper.GetValueByIndex(0);

var newsubID = subID.replace(/[^a-zA-Z0-9-]/g, &quot;&quot;);


ec_ResultHelper.ReportResultByIndex(0,newsubID);</Property>
