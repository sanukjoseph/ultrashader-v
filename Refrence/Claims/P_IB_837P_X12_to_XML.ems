myRS4.clear();
myRS4.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input5_2000C&quot;, myRS4, true);

myRS5 = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input6_2000C&quot;);
myRS5.clear();
myRS5.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input6_2000C&quot;, myRS5, true);</Property>
