		<Function ID="1110" Template="Increment">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">15</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Incrementing the value of the variable for each occurance of 2320 loop</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="variableID">140</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab15/XPos">64</Property>
				<Property Name="Tab15/YPos">-2064</Property>
			</Properties>
