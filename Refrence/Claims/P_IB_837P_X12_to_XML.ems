		<Function ID="1146" Template="Increment">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">38</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">incrementing for every occurance of 2320</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="variableID">146</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab38/XPos">64</Property>
