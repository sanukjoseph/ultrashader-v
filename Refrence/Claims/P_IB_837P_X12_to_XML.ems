		<Function ID="1769" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">8</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">var lastname = ec_DataHelper.GetValueByIndex(0);
var middlename = ec_DataHelper.GetValueByIndex(1);
var firstname = ec_DataHelper.GetValueByIndex(2);

var suffix = ec_DataHelper.GetValueByIndex(3);
var fullname ;


	fullname =lastname+&quot;,&quot; +middlename+&quot;,&quot;+firstname+&quot;,&quot;+suffix;
	
	ec_ResultHelper.ReportResultByIndex(0,fullname);
	
	</Property>
