		<Function ID="1109" Name="Service2320DetailsInput" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">15</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Record Set of Service_2320Details of 2000B Loop</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Service_2320Details&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
var resArr = new Array();

for (var i = 0; i &lt; 24; i++) resArr [i] = ec_DataHelper.GetValueByIndex(i);
	
//Updating the newly inserted row with the values from the array
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Service_2320Details&quot;, myRS, true);</Property>
