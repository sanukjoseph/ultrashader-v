			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Record Set for Claim_2320CAS</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Record Set &quot;Claim_2320CAS&quot; has information from 2320\CAS(Claim Level Adjustment).
myRS = ec_VariableHelper.GetRecordSet(&quot;Claim_2320CAS&quot;);

var resArr = new Array();

for (var i = 0; i &lt; 20; i++) 
resArr [i] = ec_DataHelper.GetValueByIndex(i);	

myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Claim_2320CAS&quot;, myRS, true);</Property>
