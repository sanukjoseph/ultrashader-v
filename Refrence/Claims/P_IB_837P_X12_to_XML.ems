		<Function ID="965" Name="JavaScript-Trigger-Drug_Identification_2410" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">43</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Drug_Identification_2410_2000C&quot;);

Fields = myRS.getFields();
if(Fields[1]!=&quot;&quot;)
{
var ndcCode = Fields[1];



 var ndcCode1 = ndcCode.substring(0,5);
 var ndcCode2 = ndcCode.substring(5,9);
 var ndcCode3 = ndcCode.substring(9);
 
 
 Fields[1] = ndcCode1+&quot;-&quot;+ndcCode2+&quot;-&quot;+ndcCode3; 
 

}

for(var i = 0; i &lt; 4; i++)
{
	// Report the value of the field at index i
	ec_ResultHelper.ReportResultByIndex(i,Fields[i]);
}</Property>
			</Properties>
