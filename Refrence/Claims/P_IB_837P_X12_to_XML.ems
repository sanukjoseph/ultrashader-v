		<Function ID="1278" Name="JavaScript-ClaimInfo_Input2" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">47</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS1 = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input2_2000B&quot;);

 resArr1 = new Array();
 
 for(i=0;i&lt;11;i++)
 {
 	resArr1[i] = ec_DataHelper.GetValueByIndex(i);
 }
 
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input2_2000B&quot;, myRS1, true);
ec_ResultHelper.ReportResultByIndex(0,&quot;Claim_Info_input2_2000B&quot;);</Property>
			</Properties>
