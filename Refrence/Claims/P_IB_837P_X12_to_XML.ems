		<Function ID="163" Name="JavaScript-Trigger-Patient Name_2010CA" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">10</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Triggering Record Set Patient_Name_2010CA and storing it in change variables</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS1 = ec_VariableHelper.GetRecordSet(&quot;Patient_Name_2010CA&quot;);
Fields1 = myRS1.getFields();//getting recordset values to Fields1
//for(var i=0;i&lt;3;i++);
ec_ResultHelper.ReportResultByIndex(0,Fields1[0]);//Mem Last name
ec_ResultHelper.ReportResultByIndex(1,Fields1[1]);
ec_ResultHelper.ReportResultByIndex(2,Fields1[2]);
ec_ResultHelper.ReportResultByIndex(3,Fields1[3]);
ec_ResultHelper.ReportResultByIndex(4,Fields1[4]);
ec_ResultHelper.ReportResultByIndex(5,Fields1[5]);
ec_ResultHelper.ReportResultByIndex(6,Fields1[6]);
ec_ResultHelper.ReportResultByIndex(7,Fields1[7]);
ec_ResultHelper.ReportResultByIndex(8,Fields1[8]);
//ec_ResultHelper.ReportResultByIndex(9,Fields1[9]);
if(Fields1[9]!= &quot;&quot;)//Country Code
{
	ec_ResultHelper.ReportResultByIndex(9,Fields1[9]);
	ec_ResultHelper.Send();
}
else
{
	ec_ResultHelper.ReportResultByIndex(9,&quot;US&quot;);
	ec_ResultHelper.Send();
}


ec_ResultHelper.ReportResultByIndex(10,Fields1[10]);
ec_ResultHelper.ReportResultByIndex(11,Fields1[11]);
ec_ResultHelper.ReportResultByIndex(12,Fields1[12]);

ec_ResultHelper.Send();

</Property>
			</Properties>
