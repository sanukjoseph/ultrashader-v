		<Function ID="1302" Name="JavaScript-ClaimInfo_Input3" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">47</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS1 = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input3_2000B&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
 resArr1 = new Array();
 
 for(i=0;i&lt;11;i++)
 {
 	resArr1[i] = ec_DataHelper.GetValueByIndex(i);
 }
 //Updating the newly inserted row with the values from the array
myRS1.insertRow();
myRS1.updateRow(resArr1);
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input3_2000B&quot;, myRS1, true);
ec_ResultHelper.ReportResultByIndex(0,&quot;Claim_Info_input3_2000B&quot;);</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab47/XPos">64</Property>
				<Property Name="Tab47/YPos">-1824</Property>
