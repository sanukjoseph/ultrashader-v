		<Function ID="1301" Name="JavaScript_RecordSet-2" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">47</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">//Reseting the recorset ie,removing junk values</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Reseting the recorset ie,removing junk values
myRS = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_2300_Input1_2000B&quot;);
myRS.clear();
myRS.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_2300_Input1_2000B&quot;, myRS, true);

myRS4 = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input2_2000B&quot;);
myRS4.clear();
myRS4.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input2_2000B&quot;, myRS4, true);


myRS3= ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input3_2000B&quot;);
myRS3.clear();
myRS3.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input3_2000B&quot;, myRS3, true);


myRS2 = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input4_2000B&quot;);
myRS2.clear();
myRS2.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input4_2000B&quot;, myRS2, true);


myRS1 = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input5_2000B&quot;);
myRS1.clear();
myRS1.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input5_2000B&quot;, myRS1, true);

myRS5 = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_input6_2000B&quot;);
myRS5.clear();
myRS5.insertRow(); 
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_input6_2000B&quot;, myRS5, true);

</Property>
