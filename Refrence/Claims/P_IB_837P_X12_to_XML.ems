		<Function ID="1134" Name="JavaScript_RecordSet-7" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">24</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Clearing Record Set LineCAS_CO_PR_2000B</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Reseting the recorset ie,removing junk values
myRS = ec_VariableHelper.GetRecordSet(&quot;ServiceAdjustment_2000B&quot;);
myRS.clear();</Property>
			</Properties>
			<Properties Category="UI">
				<Property Name="Tab24/XPos">64</Property>
