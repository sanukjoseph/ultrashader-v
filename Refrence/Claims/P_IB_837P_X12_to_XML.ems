for (var i = 0; i &lt; 5; i++)
{
  resArr [i] = ec_DataHelper.GetValueByIndex(i);	
}

myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Subscriber_Info&quot;, myRS, true);</Property>
