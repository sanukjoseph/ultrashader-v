		<Function ID="1243" Name="JavaScript-ClaimInfo_Input1" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">47</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Record set for first 11 input values of 2300 loop</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRs = ec_VariableHelper.GetRecordSet(&quot;Claim_Info_2300_Input1_2000B&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.
 resArr = new Array();
 
 for(i=0;i&lt;11;i++)
 {
 	resArr[i] = ec_DataHelper.GetValueByIndex(i);
 }
 //Updating the newly inserted row with the values from the array
myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Claim_Info_2300_Input1_2000B&quot;, myRS, true);</Property>
			</Properties>
