		<Function ID="862" Name="JavaScript-Trigger-2420A RenderingProvider" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">6</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Triggering Record set of 2420A loop.
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">//Retrieving the values from recordset and storing it in change variables outside the javascript function
myRS = ec_VariableHelper.GetRecordSet(&quot;Rendering_Prov_2420A_2000B&quot;);

Fields = myRS.getFields();

for(var i = 0; i &lt; 8; i++)
{
	ec_ResultHelper.ReportResultByIndex(i,Fields[i].trim());
}</Property>
