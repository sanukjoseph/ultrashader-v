				<ConnectionPoint ID="8442" FP="X" Pos="1" Name="CAS03,06,09,12,15,18_CoInsurance"/>
				<ConnectionPoint ID="8443" FP="X" Pos="2" Name="CAS03,06,09,12,15,18_MemberPenality "/>
				<ConnectionPoint ID="8444" FP="X" Pos="3" Name="CAS03,06,09,12,15,18_CoPay "/>
				<ConnectionPoint ID="8445" FP="X" Pos="4" Name="CAS03,06,09,12,15,18_ProviderPenality "/>
