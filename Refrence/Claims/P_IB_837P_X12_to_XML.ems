		<Function ID="63" Name="JavaScript-Record set -Pay_To_Address_2010AB" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">4</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Record Set for 2010AB loop
</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Pay_To_Address_2010AB_2000B&quot;);

var resArr = new Array();

for (var i = 0; i &lt; 6; i++)
{
  resArr [i] = ec_DataHelper.GetValueByIndex(i);// Getting the value by index and assigning it to the array	
}
// Inserting a new row into the record set
myRS.insertRow();
myRS.updateRow(resArr);// Updating the newly inserted row with the values from the array
