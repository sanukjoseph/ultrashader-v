		<Function ID="1136" Name="ServiceLineCAScodes" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">24</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">myRS3 = ec_VariableHelper.GetRecordSet(&quot;LineCAS_CO_PR_2000B&quot;);//CO PR
lx01 = ec_VariableHelper.GetVariable(&quot;LX01_ServiceLineNum_2400_2000B&quot;);
myRS3.last(); 
var RS3 = myRS3.getRow();
while (RS3&gt;0)
{
	Fields3 = myRS3.getFields();
	if(Fields3[19] == lx01)
	{
		for (var i=0; i&lt;6; i++)
		{
				if((Fields3[i*3+1] != &quot;&quot;) &amp;&amp; (Fields3[i*3+1] != &quot;undefined&quot;))
						{
							var CASamount = parseFloat(Fields3[i*3+2]);
							ec_ResultHelper.ReportResultByIndex(0, Fields3[i*3+1]);//Cascode
							ec_ResultHelper.ReportResultByIndex(1, Fields3[0]);//Groupcode
							ec_ResultHelper.ReportResultByIndex(2, parseFloat(CASamount).toFixed(2));//Amount
							ec_ResultHelper.ReportResultByIndex(3, Fields3[i*3+3]);//Quantity
							ec_ResultHelper.Send();
						}
		}
	}
	myRS3.previous();
	RS3 = myRS3.getRow();
}</Property>
			</Properties>
