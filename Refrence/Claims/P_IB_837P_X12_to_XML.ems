		<Function ID="243" Name="JavaScript-countryCode" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">13</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">javascript for mapping country code as US if the input value is null.</Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Get the value at index 0 
var countrycode = ec_DataHelper.GetValueByIndex(0);
// Check if countrycode is an empty string
if(countrycode ==&quot;&quot;)
{
	// Report &quot;US&quot; as the country code at index 0
ec_ResultHelper.ReportResultByIndex(0,&quot;US&quot;);//CountryCode
ec_ResultHelper.Send(); // Send the result
}
else
{
	// Report the retrieved country code at index 0
ec_ResultHelper.ReportResultByIndex(0,countrycode);//CountryCode
ec_ResultHelper.Send();
}
	</Property>
			</Properties>
