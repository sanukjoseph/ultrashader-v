		<Function ID="144" Name="JavaScript-RecordSet-Patient_Info_2000C" Template="JScript">
			<Properties Category="BusinessGroups">
				<Property Name="BGSet">9</Property>
			</Properties>
			<Properties Category="GlobalUserNotes">
				<Property Name="{df450e4e-e4da-45d3-a02c-cf9fcffb29f5}">Create Record Set for Patient_Info_2000C </Property>
			</Properties>
			<Properties Category="Settings">
				<Property Name="Parameters/ec_Script">// Retrieving the record set or creating the recordset
myRS = ec_VariableHelper.GetRecordSet(&quot;Patient_Info_2000C&quot;);
// Creating an empty array and Getting the value by index and assigning it to the array.Updating the newly inserted row with the values from the array
var resArr = new Array();

for (var i = 0; i &lt; 4; i++)
{
  resArr [i] = ec_DataHelper.GetValueByIndex(i);	
}

myRS.insertRow();
myRS.updateRow(resArr);
ec_VariableHelper.SetRecordSet(&quot;Patient_Info_2000C&quot;, myRS, true);</Property>
